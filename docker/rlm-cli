#!/usr/bin/env bash
#
# rlm — friendly front door to Revenue Cloud Base Foundations builds.
#
# Wraps Salesforce CLI (sf), CumulusCI (cci), the build harness, and a bundled
# Claude Code agent so someone who doesn't know any of those tools can:
#   - connect a Salesforce org (or Dev Hub)        →  rlm login
#   - build a fully configured RLM org             →  rlm build
#   - apply the build to an org they already have  →  rlm deploy
#   - customize / extend an org with AI help        →  rlm ask "..."
#
# Installed in the image at /usr/local/bin/rlm. Operates on $RLM_REPO (the baked
# snapshot, or a /work mount), set by rlm-entrypoint.

set -uo pipefail

# --------------------------------------------------------------------------- #
# Presentation helpers
# --------------------------------------------------------------------------- #
if [ -t 1 ]; then
  B=$'\033[1m'; DIM=$'\033[2m'; R=$'\033[0m'
  CY=$'\033[36m'; GR=$'\033[32m'; YL=$'\033[33m'; RD=$'\033[31m'; MG=$'\033[35m'
else
  B=""; DIM=""; R=""; CY=""; GR=""; YL=""; RD=""; MG=""
fi

say()  { printf '%s\n' "$*"; }
info() { printf '%s➜%s %s\n'  "$CY" "$R" "$*"; }
ok()   { printf '%s✔%s %s\n'  "$GR" "$R" "$*"; }
warn() { printf '%s⚠%s %s\n'  "$YL" "$R" "$*" >&2; }
err()  { printf '%s✘%s %s\n'  "$RD" "$R" "$*" >&2; }
hd()   { printf '\n%s%s%s\n'  "$B"  "$*" "$R"; }

STATE_DIR="${RLM_STATE_DIR:-$HOME/.rlm-state}"

# Be self-sufficient when invoked via `docker exec` (which inherits image ENV
# but not the entrypoint's runtime exports): recover RLM_REPO and the per-volume
# CumulusCI key so cci/sf behave identically to an interactive shell.
if [ -z "${RLM_REPO:-}" ]; then
  if [ -f /work/cumulusci.yml ]; then RLM_REPO=/work; else RLM_REPO="${RLM_BAKED_REPO:-/opt/rlm-base-dev}"; fi
  export RLM_REPO
fi
if [ -z "${CUMULUSCI_KEY:-}" ] && [ -s "$STATE_DIR/cumulusci/.rlm_cci_key" ]; then
  CUMULUSCI_KEY="$(cat "$STATE_DIR/cumulusci/.rlm_cci_key")"; export CUMULUSCI_KEY
fi

REPO="$RLM_REPO"
cd "$REPO" 2>/dev/null || { err "Repo not found at $REPO"; exit 1; }

# --------------------------------------------------------------------------- #
# Small utilities
# --------------------------------------------------------------------------- #

# Read .result[0].value from `sf config get target-dev-hub --json`.
current_devhub() {
  sf config get target-dev-hub --json 2>/dev/null \
    | jq -r '.result[0].value // empty' 2>/dev/null
}

# Username for an sf alias (empty if unknown / not authed).
org_username() {
  sf org display --target-org "$1" --json 2>/dev/null \
    | jq -r '.result.username // empty' 2>/dev/null
}

confirm() {
  # confirm "Question" — returns 0 on yes. Auto-yes when not a TTY or $ASSUME_YES.
  local prompt="$1" ans
  if [ "${ASSUME_YES:-0}" = "1" ] || [ ! -t 0 ]; then return 0; fi
  read -r -p "$prompt [Y/n] " ans
  case "${ans:-Y}" in y|Y|yes|YES|"") return 0;; *) return 1;; esac
}

rand4() { head -c 16 /dev/urandom | od -An -tx1 | tr -d ' \n' | head -c 4; }

require_ai() {
  if ! command -v claude >/dev/null 2>&1; then
    err "Claude Code is not installed in this image."; return 1
  fi
  if [ -z "${ANTHROPIC_API_KEY:-}" ] && [ ! -f "$HOME/.claude/.credentials.json" ] \
     && [ ! -f "$HOME/.claude.json" ]; then
    warn "The AI assistant isn't signed in yet."
    say  "  Easiest:   restart with  -e ANTHROPIC_API_KEY=sk-ant-...   (Console API key)"
    say  "  Or log in: ${B}rlm auth-ai${R}  (uses your Claude subscription)"
    return 1
  fi
}

