#!/usr/bin/env bash
#
# rlm — HOST launcher for the Revenue Cloud Base Foundations build container.
#
# The only command a user needs on their own machine. It wraps Docker with the
# right volume (so logins persist), ports, and mounts, and forwards everything
# to the in-container `rlm` CLI.
#
# One-off commands (fresh throwaway container each time):
#   ./docker/rlm setup              # build (or rebuild) the image
#   ./docker/rlm pull [REF]         # download a published image instead of building
#   ./docker/rlm login --devhub     # connect a Dev Hub
#   ./docker/rlm build              # build a new org
#   ./docker/rlm                    # interactive shell + welcome banner
#
# Long-running workspace (for editing + attaching Cursor / VS Code / Claude Code):
#   ./docker/rlm up                 # start a persistent named container
#   ./docker/rlm attach             # open a shell inside it
#   ./docker/rlm down               # stop + remove it
#   ./docker/rlm logs               # follow its logs
#
# Knobs (environment variables):
#   RLM_IMAGE         image tag to run/build      (default: rlm-base:latest)
#   RLM_STATE_VOLUME  named volume for auth state  (default: rlm-state)
#   RLM_CONTAINER     persistent container name    (default: rlm-base)
#   RLM_MOUNT_REPO    host path to mount at /work  (default: none for one-offs;
#                                                   the repo root for `up`)
#   RLM_OAUTH_HOST_PORT host port for the login callback (default: 1717; must be
#                       1717 to log in — override only for non-login uses, e.g. a
#                       second workspace or tests; 0 = random free port)
#   ANTHROPIC_API_KEY forwarded to the AI assistant if set
set -euo pipefail

IMAGE="${RLM_IMAGE:-rlm-base:latest}"
VOLUME="${RLM_STATE_VOLUME:-rlm-state}"
CONTAINER="${RLM_CONTAINER:-rlm-base}"
RELAY_PORT="${RLM_OAUTH_RELAY_PORT:-1718}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Resolve the rlm-base checkout. Normally it's the parent of this script, but if
# the launcher was copied onto PATH (e.g. ~/bin/rlm), that parent isn't the repo
# — fall back to $RLM_REPO_ROOT or the current directory. Commands that need the
# checkout (setup/up/build) validate it below.
REPO_ROOT=""
for _cand in "$(cd "$SCRIPT_DIR/.." 2>/dev/null && pwd)" "${RLM_REPO_ROOT:-}" "$PWD"; do
  if [ -n "$_cand" ] && [ -f "$_cand/docker/Dockerfile" ]; then REPO_ROOT="$_cand"; break; fi
done
[ -n "$REPO_ROOT" ] || REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"   # best effort

need_checkout() {  # die with guidance if $REPO_ROOT isn't an rlm-base checkout
  [ -f "$REPO_ROOT/docker/Dockerfile" ] && return 0
  die "Can't find the rlm-base checkout. Run this from the repo, or set RLM_REPO_ROOT=/path/to/rlm-base-dev (needed for: $1)."
}

c_info() { printf '\033[36m➜\033[0m %s\n' "$*"; }
c_ok()   { printf '\033[32m✔\033[0m %s\n' "$*"; }
die()    { printf '\033[31m✘\033[0m %s\n' "$*" >&2; exit 1; }

command -v docker >/dev/null 2>&1 || die "Docker is not installed. Get it at https://docs.docker.com/get-docker/"
docker info >/dev/null 2>&1 || die "Docker is installed but not running. Start Docker Desktop and try again."

# OAuth callback (rlm login): the browser redirects to localhost:1717. `localhost`
# resolves to IPv6 ::1 first on many machines (notably macOS), so we publish the
# port on BOTH loopback families to whichever the browser picks. Both forward to
# the in-container relay on RELAY_PORT.
# The HOST port must be 1717 for login — the Salesforce connected-app callback URL
# is fixed at localhost:1717. Override RLM_OAUTH_HOST_PORT only for uses that do
# NOT log in (a second workspace alongside one already holding 1717, or the smoke
# suite); set it to 0 to let Docker pick a free ephemeral host port (no collision).
HOST_OAUTH_PORT="${RLM_OAUTH_HOST_PORT:-1717}"
OAUTH_PUBLISH=(-p "127.0.0.1:${HOST_OAUTH_PORT}:${RELAY_PORT}" -p "[::1]:${HOST_OAUTH_PORT}:${RELAY_PORT}")

image_exists()     { docker image inspect "$IMAGE" >/dev/null 2>&1; }
container_running(){ [ "$(docker inspect -f '{{.State.Running}}' "$CONTAINER" 2>/dev/null)" = "true" ]; }

build_image() {
  need_checkout "building the image"
  c_info "Building $IMAGE (this takes a few minutes the first time)…"
  docker build -f "$REPO_ROOT/docker/Dockerfile" -t "$IMAGE" "$REPO_ROOT"
  c_ok "Image $IMAGE is ready."
}

ensure_image() {
  image_exists && return 0
  printf '\033[33m⚠\033[0m Image %s not found — building it now.\n' "$IMAGE"
  build_image
}

# Shared docker-run flags for one-off containers. Populates the global RUN_FLAGS
# array (no namerefs — this script must run on macOS's stock bash 3.2).
RUN_FLAGS=()
common_flags() {
  RUN_FLAGS=(--rm -v "${VOLUME}:/home/rlm/.rlm-state")
  if [ -t 0 ]; then RUN_FLAGS+=(-it); else RUN_FLAGS+=(-i); fi
  # Tell the in-container CLI how it was invoked, so its next-step hints show
  # `./docker/rlm …` (not bare `rlm`, which isn't on the host PATH).
  RUN_FLAGS+=(-e "RLM_INVOKE=${RLM_INVOKE:-./docker/rlm}")
  [ -n "${ANTHROPIC_API_KEY:-}" ] && RUN_FLAGS+=(-e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}")
  if [ -n "${RLM_MOUNT_REPO:-}" ]; then
    [ -f "${RLM_MOUNT_REPO}/cumulusci.yml" ] || die "RLM_MOUNT_REPO=${RLM_MOUNT_REPO} is not an rlm-base checkout."
    RUN_FLAGS+=(-v "$(cd "$RLM_MOUNT_REPO" && pwd):/work")
  fi
}

# --------------------------------------------------------------------------- #
# Host-only meta commands (not forwarded to the container)
# --------------------------------------------------------------------------- #
case "${1:-}" in
  setup|build-image|update-image)
    build_image; exit 0;;
  pull)
    shift; ref="${1:-$IMAGE}"; c_info "Pulling $ref…"; docker pull "$ref"
    [ "$ref" != "rlm-base:latest" ] && docker tag "$ref" rlm-base:latest && c_ok "Tagged as rlm-base:latest"
    exit 0;;
  up)
    # `up` mounts the checkout at /work (unless RLM_MOUNT_REPO overrides it).
    [ -n "${RLM_MOUNT_REPO:-}" ] || need_checkout "rlm up"
    ensure_image
    if container_running; then c_ok "Container '$CONTAINER' is already running."; exit 0; fi
    docker rm -f "$CONTAINER" >/dev/null 2>&1 || true
    # Persistent workspace: mount the repo root at /work so edits persist on the
    # host, publish the OAuth port for in-container `rlm login`, keep auth state.
    up_flags=(-d --name "$CONTAINER"
              -v "${VOLUME}:/home/rlm/.rlm-state"
              -v "${RLM_MOUNT_REPO:-$REPO_ROOT}:/work"
              "${OAUTH_PUBLISH[@]}"
              -e "RLM_OAUTH_RELAY_PORT=${RELAY_PORT}")
    [ -n "${ANTHROPIC_API_KEY:-}" ] && up_flags+=(-e "ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}")
    c_info "Starting persistent container '$CONTAINER'…"
    docker run "${up_flags[@]}" "$IMAGE" serve >/dev/null
    c_ok "Up. Attach a shell:  ./docker/rlm attach"
    printf '   Connect Cursor/VS Code: \033[1mDev Containers: Attach to Running Container…\033[0m → %s\n' "$CONTAINER"
    exit 0;;
  attach)
    container_running || die "Container '$CONTAINER' isn't running. Start it with: ./docker/rlm up"
    exec docker exec -it "$CONTAINER" bash -l;;
  down|stop)
    docker rm -f "$CONTAINER" >/dev/null 2>&1 && c_ok "Stopped '$CONTAINER'." || c_info "No container '$CONTAINER' to stop."
    exit 0;;
  logs)
    exec docker logs -f "$CONTAINER";;
esac

# --------------------------------------------------------------------------- #
# One-off command: forward to the in-container rlm CLI in a throwaway container
# --------------------------------------------------------------------------- #
# Long builds need durable artifacts so `rlm resume` works and you can read the
# report afterward. When run from a checkout, mount it at /work by default so
# .harness checkpoints/logs land on the host (and survive the throwaway container).
case "${1:-}" in
  build|resume)
    # The build harness writes .harness/runs/<id> under the repo, and `resume`
    # needs that checkpoint later — so it must persist OUTSIDE the throwaway
    # container. Require a checkout to mount at /work (a no-checkout build would
    # leave the run dir in the --rm container, breaking resume). Org commands
    # still work from anywhere.
    if [ -z "${RLM_MOUNT_REPO:-}" ]; then
      need_checkout "rlm $1 (needs a place to save .harness for resume)"
      RLM_MOUNT_REPO="$REPO_ROOT"
    fi
    printf '\033[2m(build artifacts saved in %s/.harness — resumable)\033[0m\n' "$RLM_MOUNT_REPO"
    ;;
  deploy)
    # deploy uses cci directly (no .harness), so a checkout is optional — mount
    # it if present, else fall back to the baked repo.
    if [ -z "${RLM_MOUNT_REPO:-}" ] && [ -f "$REPO_ROOT/cumulusci.yml" ]; then
      RLM_MOUNT_REPO="$REPO_ROOT"
    fi
    ;;
esac

ensure_image
common_flags
# Sign-in needs the OAuth callback port: the browser's localhost:1717 redirect
# reaches sf's loopback server inside the container via a relay on RELAY_PORT.
# The --auth-url import path is callback-free, so skip the port there.
case "${1:-}" in
  login|connect)
    _authurl=0
    for _a in "$@"; do case "$_a" in --auth-url|--from-stdin) _authurl=1;; esac; done
    [ "$_authurl" = "0" ] && RUN_FLAGS+=("${OAUTH_PUBLISH[@]}" -e "RLM_OAUTH_RELAY_PORT=${RELAY_PORT}")
    ;;
  start|welcome|begin)
    # The guided menu can launch a browser sign-in (cmd_login), which needs the
    # OAuth callback port published just like `login`.
    RUN_FLAGS+=("${OAUTH_PUBLISH[@]}" -e "RLM_OAUTH_RELAY_PORT=${RELAY_PORT}")
    ;;
esac

exec docker run "${RUN_FLAGS[@]}" "$IMAGE" "$@"
