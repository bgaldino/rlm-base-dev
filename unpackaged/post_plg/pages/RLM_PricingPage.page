<!-- ═══ JAVASCRIPT ═══ -->
<!-- ═══════════════════════════════════════════════════════ -->
<script>
//<![CDATA[
var currentBilling = 'annual';
var selectedTrialPlan = 'Pro';
var upgradePlan = 'Pro';
var upgradeStep = 1;

var currentUser = null;
var pendingAction = null;
var pendingPlan = null;
var activatedTrials = {};
var purchasedPlans = {};
var changePlanAssetId = null;
var currentOrderId = null;

/* ── Auth State ──────────────────────────────────────── */
function setCurrentUser(user) {
    currentUser = user;
    if (user) {
        document.getElementById('navCtaGuest').classList.add('hidden');
        document.getElementById('navCtaUser').classList.remove('hidden');
        document.getElementById('navUserName').textContent = user.firstName + ' ' + user.lastName;
        document.getElementById('navUserAvatar').textContent = (user.firstName || '?').charAt(0).toUpperCase();
    } else {
        document.getElementById('navCtaGuest').classList.remove('hidden');
        document.getElementById('navCtaUser').classList.add('hidden');
        document.getElementById('navUserName').textContent = '';
    }
}

function logoutUser() {
    setCurrentUser(null);
    showToast('You have been logged out.', false);
}

/* ── Auth Modal ──────────────────────────────────────── */
function openAuthModal(tab, action, plan) {
    if (action) { pendingAction = action; pendingPlan = plan || null; }
    switchAuthTab(tab || 'login');

    var subtitle = 'Log in or create an account to continue';
    if (pendingAction === 'trial')  subtitle = 'Log in or create an account to start your free trial';
    if (pendingAction === 'quote')  subtitle = 'Log in or create an account to request a quote';
    document.getElementById('authSubtitle').textContent = subtitle;

    hideAuthError();
    openModal('authModal');
}

function switchAuthTab(tab) {
    document.getElementById('tabLogin').classList.toggle('active', tab === 'login');
    document.getElementById('tabRegister').classList.toggle('active', tab === 'register');
    document.getElementById('viewLogin').classList.toggle('active', tab === 'login');
    document.getElementById('viewRegister').classList.toggle('active', tab === 'register');
    hideAuthError();
}

function showAuthError(msg) {
    var el = document.getElementById('authError');
    el.textContent = msg;
    el.classList.add('visible');
}
function hideAuthError() {
    document.getElementById('authError').classList.remove('visible');
}

function togglePassword(inputId, btn) {
    var inp = document.getElementById(inputId);
    if (inp.type === 'password') { inp.type = 'text'; btn.textContent = 'Hide'; }
    else { inp.type = 'password'; btn.textContent = 'Show'; }
}

/* ── Handle Plan Button Clicks ───────────────────────── */
function handlePlanAction(action, plan) {
    if (action === 'change') {
        changePlanAssetId = purchasedPlans[plan] || null;
        upgradePlan = plan;
        openUpgradeModal();
        return;
    }
    if (action === 'trial' && activatedTrials[plan]) {
        upgradePlan = plan;
        openUpgradeModal();
        return;
    }
    if (currentUser) {
        executePlanAction(action, plan);
    } else {
        openAuthModal('register', action, plan);
    }
}

function executePlanAction(action, plan) {
    if (action === 'change') {
        changePlanAssetId = purchasedPlans[plan] || null;
        upgradePlan = plan;
        openUpgradeModal();
        return;
    }
    if (action === 'trial') {
        if (activatedTrials[plan]) { upgradePlan = plan; openUpgradeModal(); return; }
        startTrialForUser(plan);
    } else if (action === 'quote') {
        openContactModal(plan);
    }
}

function switchButtonToPaid(plan) {
    var btn = document.getElementById('btn' + plan);
    if (!btn) return;
    btn.textContent = 'Upgrade to Paid';
    btn.className = 'btn btn-accent';
}

function switchButtonToChangePlan(plan) {
    var btn = document.getElementById('btn' + plan);
    if (!btn) return;
    btn.textContent = 'Change Plan';
    btn.className = 'btn btn-accent';
    btn.setAttribute('onclick', "handlePlanAction('change','" + plan + "')");
}

/* ── Login Handler ───────────────────────────────────── */
function handleLogin(e) {
    e.preventDefault();
    hideAuthError();
    var btn = document.getElementById('loginSubmitBtn');
    setLoading(btn, 'loginBtnText', 'loginBtnSpinner', true);

    var email = document.getElementById('loginEmail').value;
    var password = document.getElementById('loginPassword').value;

    Visualforce.remoting.Manager.invokeAction(
        '{!$RemoteAction.RLM_PricingPageController.loginUser}',
        email, password,
        function(result, event) {
            setLoading(btn, 'loginBtnText', 'loginBtnSpinner', false);
            if (event.status && result.success) {
                setCurrentUser(result);
                closeModal('authModal');
                showToast(result.message, false);
                document.getElementById('loginForm').reset();
                if (pendingAction) {
                    var a = pendingAction, p = pendingPlan;
                    pendingAction = null; pendingPlan = null;
                    setTimeout(function(){ executePlanAction(a, p); }, 400);
                }
            } else {
                showAuthError(result ? result.message : event.message);
            }
        },
        { escape: false }
    );
    return false;
}

/* ── Register Handler ────────────────────────────────── */
function handleRegister(e) {
    e.preventDefault();
    hideAuthError();

    var pw = document.getElementById('regPassword').value;
    var pwConfirm = document.getElementById('regPasswordConfirm').value;
    if (pw !== pwConfirm) {
        showAuthError('Passwords do not match.');
        return false;
    }
    if (pw.length < 8) {
        showAuthError('Password must be at least 8 characters.');
        return false;
    }

    var btn = document.getElementById('regSubmitBtn');
    setLoading(btn, 'regBtnText', 'regBtnSpinner', true);

    Visualforce.remoting.Manager.invokeAction(
        '{!$RemoteAction.RLM_PricingPageController.registerUser}',
        document.getElementById('regFirstName').value,
        document.getElementById('regLastName').value,
        document.getElementById('regEmail').value,
        pw,
        document.getElementById('regCompany').value,
        function(result, event) {
            setLoading(btn, 'regBtnText', 'regBtnSpinner', false);
            if (event.status && result.success) {
                setCurrentUser(result);
                closeModal('authModal');
                showToast('Account created! Welcome to NovaSpark, ' + result.firstName + '.', false);
                document.getElementById('registerForm').reset();
                if (pendingAction) {
                    var a = pendingAction, p = pendingPlan;
                    pendingAction = null; pendingPlan = null;
                    setTimeout(function(){ executePlanAction(a, p); }, 400);
                }
            } else {
                showAuthError(result ? result.message : event.message);
            }
        },
        { escape: false }
    );
    return false;
}

/* ── Start Trial (after auth) ────────────────────────── */
function startTrialForUser(plan) {
    if (!currentUser) return;
    showToast('Starting your ' + plan + ' trial...', false);

    Visualforce.remoting.Manager.invokeAction(
        '{!$RemoteAction.RLM_PricingPageController.startFreeTrial}',
        currentUser.firstName,
        currentUser.lastName,
        currentUser.email,
        currentUser.company,
        plan,
        function(result, event) {
            if (event.status && result.success) {
                activatedTrials[plan] = true;
                switchButtonToPaid(plan);
                showToast(result.message, false);
            } else {
                showToast(result ? result.message : event.message, true);
            }
        },
        { escape: false }
    );
}

/* ── Contact Sales Modal (after auth) ────────────────── */
function openContactModal(plan) {
    if (!currentUser) { openAuthModal('register', 'quote', plan); return; }
    document.getElementById('contactAuthName').textContent = currentUser.firstName + ' ' + currentUser.lastName;
    document.getElementById('contactAuthEmail').textContent = currentUser.email;
    openModal('contactModal');
}

function handleContactSubmit(e) {
    e.preventDefault();
    if (!currentUser) return;
    var btn = document.getElementById('contactSubmitBtn');
    setLoading(btn, 'contactBtnText', 'contactBtnSpinner', true);

    Visualforce.remoting.Manager.invokeAction(
        '{!$RemoteAction.RLM_PricingPageController.requestQuote}',
        currentUser.firstName,
        currentUser.lastName,
        currentUser.email,
        currentUser.company,
        document.getElementById('contactPhone').value,
        'Enterprise',
        parseInt(document.getElementById('contactSeats').value) || 10,
        document.getElementById('contactMessage').value,
        function(result, event) {
            setLoading(btn, 'contactBtnText', 'contactBtnSpinner', false);
            if (event.status && result.success) {
                closeModal('contactModal');
                showToast(result.message, false);
                document.getElementById('contactForm').reset();
            } else {
                showToast(result ? result.message : event.message, true);
            }
        },
        { escape: false }
    );
    return false;
}

/* ── Billing Toggle ─────────────────────────────────── */
function setBilling(cycle) {
    currentBilling = cycle;
    document.querySelectorAll('.toggle-label').forEach(function(el) {
        el.classList.toggle('active', el.getAttribute('data-cycle') === cycle);
    });
    document.querySelectorAll('.pricing-section .amount[data-monthly]').forEach(function(el) {
        el.textContent = el.getAttribute('data-' + cycle);
    });
}

/* ── Modals ──────────────────────────────────────────── */
function openModal(id)  { document.getElementById(id).classList.add('visible'); }
function closeModal(id) { document.getElementById(id).classList.remove('visible'); }

function openUpgradeModal()  { goToUpgradeStep(1); openModal('upgradeModal'); }

document.querySelectorAll('.modal-overlay').forEach(function(overlay) {
    overlay.addEventListener('click', function(e) {
        if (e.target === overlay) closeModal(overlay.id);
    });
});

/* ── Upgrade Wizard ─────────────────────────────────── */
function goToUpgradeStep(step) {
    upgradeStep = step;
    for (var i = 1; i <= 5; i++) {
        document.getElementById('upgradeStep' + i).classList.toggle('hidden', i !== step);
    }
    document.querySelectorAll('.stepper .step').forEach(function(el) {
        var s = parseInt(el.getAttribute('data-step'));
        el.classList.toggle('active', s === step);
        el.classList.toggle('done', s < step);
    });
    if (step === 2) recalcPrice();
    if (step === 3) updateReview();
}

function selectUpgradePlan(el, plan) {
    upgradePlan = plan;
    document.querySelectorAll('#upgradeStep1 .card').forEach(function(c) {
        c.style.borderColor = c.getAttribute('data-plan') === plan ? 'var(--primary)' : 'var(--border)';
    });
}

function adjustSeats(delta) {
    var inp = document.getElementById('upgradeSeats');
    var v = Math.max(1, parseInt(inp.value || 1) + delta);
    inp.value = v;
    recalcPrice();
}

function getPlanBasePrice(plan, term) {
    var prices = {
        'Starter':    { monthly: 39,  annual: 29  },
        'Pro':        { monthly: 79,  annual: 59  },
        'Enterprise': { monthly: 199, annual: 159 }
    };
    var p = prices[plan] || prices['Pro'];
    return term === 'annual' ? p.annual : p.monthly;
}

function recalcPrice() {
    var seats = parseInt(document.getElementById('upgradeSeats').value) || 1;
    var term  = document.getElementById('upgradeTerm').value;
    var base  = getPlanBasePrice(upgradePlan, term);
    var total = base * seats * (term === 'annual' ? 12 : 1);

    document.getElementById('calcBase').textContent  = '$' + base.toFixed(2);
    document.getElementById('calcSeats').textContent  = '\u00d7 ' + seats;
    document.getElementById('calcDiscount').textContent = term === 'annual' ? '20% (included)' : '$0';
    document.getElementById('calcTotal').textContent = '$' + total.toLocaleString() + (term === 'annual' ? '/yr' : '/mo');
}

function updateReview() {
    var seats = parseInt(document.getElementById('upgradeSeats').value) || 1;
    var term  = document.getElementById('upgradeTerm').value;
    var base  = getPlanBasePrice(upgradePlan, term);
    var total = base * seats * (term === 'annual' ? 12 : 1);

    document.getElementById('reviewPlan').textContent  = upgradePlan;
    document.getElementById('reviewSeats').textContent  = seats;
    document.getElementById('reviewTerm').textContent   = term === 'annual' ? 'Annual (12 months)' : 'Monthly';
    document.getElementById('reviewTotal').textContent  = '$' + total.toLocaleString() + (term === 'annual' ? '/yr' : '/mo');
    document.getElementById('payTotal').textContent     = '$' + total.toLocaleString();
}

function placeOrder() {
    if (!document.getElementById('agreeTerms').checked) {
        showToast('Please agree to the terms to continue.', true);
        return;
    }
    var btn = document.getElementById('placeOrderBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Creating Order...';

    var seats = parseInt(document.getElementById('upgradeSeats').value) || 1;
    var term  = document.getElementById('upgradeTerm').value;
    var acctId = currentUser ? currentUser.accountId : '';

    Visualforce.remoting.Manager.invokeAction(
        '{!$RemoteAction.RLM_PricingPageController.createOrder}',
        acctId, upgradePlan, seats, term,
        function(result, event) {
            btn.disabled = false;
            btn.innerHTML = 'Place Order &amp; Proceed to Payment &rarr;';
            if (event.status && result.success) {
                currentOrderId = result.orderId;
                var base = getPlanBasePrice(upgradePlan, term);
                var total = base * seats * (term === 'annual' ? 12 : 1);
                document.getElementById('payTotal').textContent = '$' + total.toLocaleString();
                showToast('Order ' + (result.orderNumber || '') + ' created! Proceed to payment.', false);
                goToUpgradeStep(4);
            } else {
                showToast(result ? result.message : event.message, true);
            }
        },
        { escape: false }
    );
}

function processPayment() {
    var btn = document.getElementById('payBtn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Processing Payment...';

    var seats = parseInt(document.getElementById('upgradeSeats').value) || 1;
    var term  = document.getElementById('upgradeTerm').value;

    if (!currentOrderId) {
        showToast('No order found. Please go back and place the order first.', true);
        btn.disabled = false;
        btn.innerHTML = '&#x1F512; Pay &amp; Activate &rarr;';
        return;
    }

    Visualforce.remoting.Manager.invokeAction(
        '{!$RemoteAction.RLM_PricingPageController.activateOrderAndCreateAsset}',
        currentOrderId,
        function(result, event) {
            btn.disabled = false;
            btn.innerHTML = '&#x1F512; Pay &amp; Activate &rarr;';
            if (event.status && result.success) {
                var base = getPlanBasePrice(upgradePlan, term);
                var total = base * seats * (term === 'annual' ? 12 : 1);
                document.getElementById('invPlan').textContent   = upgradePlan + ' ' + (term === 'annual' ? 'Annual' : 'Monthly');
                document.getElementById('invAmount').textContent = '$' + total.toLocaleString();
                document.getElementById('invNumber').textContent = result.orderNumber || '-';

                var payEl = document.getElementById('invPayment');
                if (result.paymentCreated) {
                    payEl.textContent = '#' + (result.paymentNumber || 'Processed');
                    payEl.style.color = 'var(--success)';
                } else {
                    payEl.textContent = 'Pending';
                    payEl.style.color = 'var(--accent)';
                }

                var invEl = document.getElementById('invInvoice');
                if (result.invoiceCreated) {
                    invEl.textContent = 'Generated';
                    invEl.style.color = 'var(--success)';
                } else {
                    invEl.textContent = result.invoiceMessage || 'Auto-generated on billing run';
                    invEl.style.color = 'var(--text-secondary)';
                }

                showToast(result.message, false);

                purchasedPlans[upgradePlan] = true;
                switchButtonToChangePlan(upgradePlan);

                if (changePlanAssetId) {
                    cancelOldSubscription(changePlanAssetId);
                    changePlanAssetId = null;
                }

                goToUpgradeStep(5);
            } else {
                showToast(result ? result.message : event.message, true);
            }
        },
        { escape: false }
    );
}

function cancelOldSubscription(assetId) {
    Visualforce.remoting.Manager.invokeAction(
        '{!$RemoteAction.RLM_PricingPageController.cancelSubscription}',
        assetId,
        function(result, event) {
            if (event.status && result.success) {
                showToast('Previous subscription cancelled.', false);
            }
        },
        { escape: false }
    );
}

function openChangePlanFromDash(assetId, currentPlan) {
    closeModal('dashboardModal');
    changePlanAssetId = assetId;
    upgradePlan = 'Pro';
    openUpgradeModal();
}

/* ── My Dashboard ──────────────────────────────────── */
function openDashboard() {
    if (!currentUser || !currentUser.accountId) {
        showToast('Please log in to view your dashboard.', true);
        return;
    }
    openModal('dashboardModal');
    document.getElementById('dashLoading').classList.remove('hidden');
    document.getElementById('dashContent').classList.add('hidden');

    Visualforce.remoting.Manager.invokeAction(
        '{!$RemoteAction.RLM_PricingPageController.getMyDashboard}',
        currentUser.accountId,
        function(res, event) {
            document.getElementById('dashLoading').classList.add('hidden');
            document.getElementById('dashContent').classList.remove('hidden');
            if (event.status && res.success) {
                renderDashAssets(res.assets || []);
                renderDashOrders(res.orders || []);
                renderDashPayments(res.payments || []);
                renderDashQuotes(res.quotes || []);
            } else {
                showToast(res ? res.message : event.message, true);
            }
        },
        { escape: false }
    );
}

function dashStatusBadge(status) {
    var colors = {
        'Installed': '#059669', 'Active': '#059669', 'Activated': '#059669',
        'Draft': '#6366f1', 'Obsolete': '#94a3b8', 'Cancelled': '#ef4444'
    };
    var c = colors[status] || '#6366f1';
    return '<span style="display:inline-block;padding:2px 10px;border-radius:20px;font-size:.75rem;font-weight:600;'
        + 'background:' + c + '18;color:' + c + '">' + (status || 'N/A') + '</span>';
}

function dashMoney(val) {
    if (val == null) return '-';
    return '$' + Number(val).toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
}

function dashDate(val) {
    if (!val) return '-';
    return new Date(val).toLocaleDateString('en-US', {month: 'short', day: 'numeric', year: 'numeric'});
}

function renderDashAssets(items) {
    var el = document.getElementById('dashAssets');
    var empty = document.getElementById('dashAssetsEmpty');
    if (!items.length) { el.innerHTML = ''; empty.classList.remove('hidden'); return; }
    empty.classList.add('hidden');
    var html = '<div style="display:grid;gap:.75rem">';
    for (var i = 0; i < items.length; i++) {
        var a = items[i];
        var cycleLabel = a.billingCycle ? a.billingCycle : '';
        var priceLabel = '';
        if (a.unitPrice) {
            priceLabel = dashMoney(a.unitPrice) + '/seat' + (cycleLabel ? ' &middot; ' + cycleLabel : '');
        } else if (cycleLabel) {
            priceLabel = cycleLabel;
        }
        var isActive = a.status && a.status !== 'Obsolete' && a.status !== 'Cancelled';
        html += '<div style="background:#F9FAFB;border-radius:10px;padding:1rem;display:grid;grid-template-columns:1fr auto;align-items:center;gap:.5rem">'
            + '<div>'
            + '<div style="font-weight:700;font-size:.95rem">' + (a.product || a.name) + '</div>'
            + '<div style="font-size:.82rem;color:var(--text-secondary)">'
            + (priceLabel ? priceLabel + ' &middot; ' : '')
            + 'Qty: ' + (a.quantity || 1)
            + (a.managed ? ' &middot; <span style="color:var(--primary);font-weight:600">Managed</span>' : '')
            + '</div></div>'
            + '<div style="text-align:right;display:flex;flex-direction:column;align-items:flex-end;gap:.35rem">'
            + dashStatusBadge(a.status)
            + (isActive && a.managed
                ? '<button class="btn btn-accent" style="padding:.35rem 1rem;font-size:.78rem;min-width:auto" '
                  + 'onclick="openChangePlanFromDash(\'' + a.id + '\',\'' + (a.product || a.name) + '\')">'
                  + 'Change Plan</button>'
                : '')
            + '</div></div>';
    }
    html += '</div>';
    el.innerHTML = html;
}

function renderDashOrders(items) {
    var el = document.getElementById('dashOrders');
    var empty = document.getElementById('dashOrdersEmpty');
    if (!items.length) { el.innerHTML = ''; empty.classList.remove('hidden'); return; }
    empty.classList.add('hidden');
    var html = '<div style="display:grid;gap:.75rem">';
    for (var i = 0; i < items.length; i++) {
        var o = items[i];
        var lines = o.lineItems || [];
        var lineHtml = '';
        for (var j = 0; j < lines.length; j++) {
            lineHtml += '<div style="font-size:.82rem;color:var(--text-secondary)">'
                + lines[j].product + ' &times; ' + lines[j].quantity
                + ' @ ' + dashMoney(lines[j].price) + '</div>';
        }
        html += '<div style="background:#F9FAFB;border-radius:10px;padding:1rem">'
            + '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.25rem">'
            + '<span style="font-weight:700">Order #' + o.number + '</span>'
            + dashStatusBadge(o.status) + '</div>'
            + lineHtml
            + '<div style="display:flex;justify-content:space-between;margin-top:.35rem;font-size:.85rem">'
            + '<span style="color:var(--text-secondary)">' + dashDate(o.date) + '</span>'
            + '<span style="font-weight:700">' + dashMoney(o.total) + '</span></div></div>';
    }
    html += '</div>';
    el.innerHTML = html;
}

function renderDashPayments(items) {
    var el = document.getElementById('dashPayments');
    var empty = document.getElementById('dashPaymentsEmpty');
    if (!items.length) { el.innerHTML = ''; empty.classList.remove('hidden'); return; }
    empty.classList.add('hidden');
    var html = '<div style="display:grid;gap:.75rem">';
    for (var i = 0; i < items.length; i++) {
        var p = items[i];
        html += '<div style="background:#F9FAFB;border-radius:10px;padding:1rem">'
            + '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.25rem">'
            + '<span style="font-weight:700">Payment #' + p.number + '</span>'
            + dashStatusBadge(p.status) + '</div>'
            + '<div style="font-size:.82rem;color:var(--text-secondary)">'
            + (p.ref ? 'Ref: ' + p.ref : '') + '</div>'
            + '<div style="display:flex;justify-content:space-between;margin-top:.35rem;font-size:.85rem">'
            + '<span style="color:var(--text-secondary)">' + dashDate(p.date) + '</span>'
            + '<span style="font-weight:700;color:var(--success)">' + dashMoney(p.amount) + '</span></div></div>';
    }
    html += '</div>';
    el.innerHTML = html;
}

function renderDashQuotes(items) {
    var el = document.getElementById('dashQuotes');
    var empty = document.getElementById('dashQuotesEmpty');
    if (!items.length) { el.innerHTML = ''; empty.classList.remove('hidden'); return; }
    empty.classList.add('hidden');
    var html = '<div style="display:grid;gap:.75rem">';
    for (var i = 0; i < items.length; i++) {
        var q = items[i];
        var lines = q.lineItems || [];
        var lineHtml = '';
        for (var j = 0; j < lines.length; j++) {
            lineHtml += '<div style="font-size:.82rem;color:var(--text-secondary)">'
                + lines[j].product + ' &times; ' + lines[j].quantity
                + ' @ ' + dashMoney(lines[j].price) + '</div>';
        }
        html += '<div style="background:#F9FAFB;border-radius:10px;padding:1rem">'
            + '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.25rem">'
            + '<span style="font-weight:700">Quote #' + q.number + '</span>'
            + dashStatusBadge(q.status) + '</div>'
            + '<div style="font-size:.85rem;margin-bottom:.25rem">' + q.name + '</div>'
            + lineHtml
            + '<div style="display:flex;justify-content:space-between;margin-top:.35rem;font-size:.85rem">'
            + '<span style="color:var(--text-secondary)">Expires: ' + dashDate(q.expires) + '</span>'
            + '<span style="font-weight:700">' + dashMoney(q.total) + '</span></div></div>';
    }
    html += '</div>';
    el.innerHTML = html;
}

/* ── FAQ Toggle ─────────────────────────────────────── */
function toggleFaq(btn) {
    btn.parentElement.classList.toggle('open');
}

/* ── Helpers ─────────────────────────────────────────── */
function setLoading(btn, textId, spinnerId, loading) {
    btn.disabled = loading;
    document.getElementById(textId).classList.toggle('hidden', loading);
    document.getElementById(spinnerId).classList.toggle('hidden', !loading);
}

function showToast(msg, isError) {
    var t = document.getElementById('toast');
    t.className = 'toast visible' + (isError ? ' error' : '');
    document.getElementById('toastMsg').textContent = msg;
    setTimeout(function(){ t.classList.remove('visible'); }, 5000);
}
