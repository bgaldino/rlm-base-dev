<apex:page controller="RLM_PricingPageController" showHeader="false" sidebar="false"
           standardStylesheets="false" applyHtmlTag="false" applyBodyTag="false"
           docType="html-5.0" cache="false">
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Pricing &mdash; NovaSpark AI</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
<style>
/* ── Reset and Base ────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --primary:#7C3AED;--primary-dark:#6D28D9;--primary-light:#A78BFA;
  --accent:#F59E0B;--accent-hover:#D97706;
  --bg:#0B0F1A;--bg-section:#111827;--bg-card:#FFFFFF;
  --text:#F9FAFB;--text-muted:#9CA3AF;--text-dark:#1F2937;--text-secondary:#6B7280;
  --border:#E5E7EB;--border-dark:#374151;
  --success:#10B981;--danger:#EF4444;
  --radius:12px;--radius-lg:16px;
  --shadow:0 4px 6px -1px rgba(0,0,0,.1),0 2px 4px -2px rgba(0,0,0,.1);
  --shadow-lg:0 20px 25px -5px rgba(0,0,0,.1),0 8px 10px -6px rgba(0,0,0,.1);
  --shadow-xl:0 25px 50px -12px rgba(0,0,0,.25);
}
html{font-family:'Inter',system-ui,-apple-system,sans-serif;scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);line-height:1.6;-webkit-font-smoothing:antialiased}
a{color:var(--primary-light);text-decoration:none}
a:hover{text-decoration:underline}

/* ── Navigation ────────────────────────────────────────── */
.nav{position:sticky;top:0;z-index:100;background:rgba(11,15,26,.85);backdrop-filter:blur(12px);border-bottom:1px solid var(--border-dark);padding:0 2rem}
.nav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:64px}
.logo{font-size:1.35rem;font-weight:800;color:#fff;display:flex;align-items:center;gap:.5rem}
.logo span{background:linear-gradient(135deg,var(--primary),#EC4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{color:var(--text-muted);font-size:.9rem;font-weight:500;transition:color .2s}
.nav-links a:hover{color:#fff;text-decoration:none}
.nav-cta .btn-sm{padding:.5rem 1.2rem;font-size:.85rem;border-radius:8px;font-weight:600;cursor:pointer;transition:all .2s}
.btn-ghost{background:transparent;border:1px solid var(--border-dark);color:#fff}
.btn-ghost:hover{border-color:var(--primary-light);color:var(--primary-light)}
.btn-accent-sm{background:var(--accent);border:none;color:#000;margin-left:.5rem}
.btn-accent-sm:hover{background:var(--accent-hover)}

/* ── User greeting in nav ─────────────────────────────── */
.nav-user{display:flex;align-items:center;gap:.75rem}
.nav-user-name{color:var(--primary-light);font-size:.85rem;font-weight:600}
.nav-user-avatar{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--primary),#EC4899);display:flex;align-items:center;justify-content:center;color:#fff;font-size:.8rem;font-weight:700}

/* ── Hero ──────────────────────────────────────────────── */
.hero{text-align:center;padding:5rem 2rem 2rem;background:radial-gradient(ellipse at top,rgba(124,58,237,.15),transparent 70%)}
.hero h1{font-size:clamp(2rem,5vw,3.2rem);font-weight:800;letter-spacing:-.02em;margin-bottom:1rem}
.hero h1 em{font-style:normal;background:linear-gradient(135deg,var(--primary-light),#EC4899);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hero p{color:var(--text-muted);font-size:1.1rem;max-width:600px;margin:0 auto 2rem}

/* ── Billing Toggle ────────────────────────────────────── */
.toggle-wrap{display:inline-flex;align-items:center;gap:1rem;background:var(--bg-section);border:1px solid var(--border-dark);border-radius:40px;padding:.35rem .5rem;margin-bottom:3rem}
.toggle-label{font-size:.9rem;font-weight:500;color:var(--text-muted);padding:.4rem .8rem;border-radius:30px;cursor:pointer;transition:all .25s}
.toggle-label.active{background:var(--primary);color:#fff}
.toggle-badge{font-size:.7rem;font-weight:700;background:linear-gradient(135deg,var(--accent),#F97316);color:#000;padding:.15rem .5rem;border-radius:20px;margin-left:.25rem}

/* ── Pricing Grid ──────────────────────────────────────── */
.pricing-section{max-width:1200px;margin:0 auto;padding:0 2rem 5rem}
.pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;align-items:start}
@media(max-width:900px){.pricing-grid{grid-template-columns:1fr;max-width:420px;margin:0 auto}}

/* ── Card ──────────────────────────────────────────────── */
.card{background:var(--bg-card);border-radius:var(--radius-lg);padding:2rem;position:relative;transition:transform .3s,box-shadow .3s;color:var(--text-dark)}
.card:hover{transform:translateY(-4px);box-shadow:var(--shadow-xl)}
.card.featured{border:2px solid var(--primary);box-shadow:0 0 40px rgba(124,58,237,.2)}
.popular-badge{position:absolute;top:-14px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,var(--primary),#EC4899);color:#fff;font-size:.7rem;font-weight:700;padding:.35rem 1rem;border-radius:20px;letter-spacing:.05em;white-space:nowrap}
.card-icon{font-size:1.6rem;margin-bottom:.75rem;display:inline-block}
.card h3{font-size:1.25rem;font-weight:700;margin-bottom:.5rem}
.price{display:flex;align-items:baseline;gap:.25rem;margin-bottom:.25rem}
.price .amount{font-size:2.75rem;font-weight:800;line-height:1}
.price .currency{font-size:1.2rem;font-weight:600;color:var(--text-secondary)}
.price .period{font-size:.85rem;color:var(--text-secondary);font-weight:500}
.price-custom .amount{font-size:2rem}
.card-desc{color:var(--text-secondary);font-size:.9rem;margin-bottom:1.5rem;min-height:2.8rem}
.btn{padding:.75rem 1.5rem;font-size:.95rem;font-weight:600;border-radius:10px;cursor:pointer;border:none;transition:all .25s ease;display:inline-flex;align-items:center;justify-content:center;gap:.4rem;font-family:inherit;line-height:1.4;letter-spacing:.01em}
.card .btn{width:100%}
.btn-primary{background:var(--primary);color:#fff}
.btn-primary:hover{background:var(--primary-dark);box-shadow:0 4px 15px rgba(124,58,237,.4)}
.btn-outline{background:transparent;border:2px solid var(--border);color:var(--text-dark)}
.btn-outline:hover{border-color:var(--primary);color:var(--primary)}
.btn-accent{background:var(--accent);color:#000}
.btn-accent:hover{background:var(--accent-hover)}
.card hr{border:none;border-top:1px solid var(--border);margin:1.5rem 0}
.feature-heading{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text-secondary);margin-bottom:.75rem}
.feature-list{list-style:none;display:flex;flex-direction:column;gap:.6rem}
.feature-list li{font-size:.88rem;color:var(--text-secondary);display:flex;align-items:flex-start;gap:.5rem}
.feature-list li::before{content:'\2713';color:var(--success);font-weight:700;flex-shrink:0;margin-top:1px}
.feature-list li.disabled::before{content:'\2014';color:var(--text-muted)}

/* ── API Badge ─────────────────────────────────────────── */
.api-badge{display:inline-block;font-family:'SF Mono',SFMono-Regular,Menlo,monospace;font-size:.7rem;background:rgba(124,58,237,.1);color:var(--primary-light);border:1px solid rgba(124,58,237,.25);padding:.25rem .6rem;border-radius:6px;margin-bottom:1rem;letter-spacing:.02em}
.api-badge-dark{background:rgba(124,58,237,.15);border-color:rgba(124,58,237,.3)}

/* ── Feature Comparison ────────────────────────────────── */
.comparison{max-width:1100px;margin:0 auto;padding:0 2rem 5rem}
.comparison h2{text-align:center;font-size:1.8rem;font-weight:700;margin-bottom:2.5rem}
.compare-table{width:100%;border-collapse:collapse;font-size:.88rem}
.compare-table th,.compare-table td{padding:.85rem 1rem;text-align:left;border-bottom:1px solid var(--border-dark)}
.compare-table th{color:var(--text-muted);font-weight:600}
.compare-table td{color:var(--text)}
.compare-table td:first-child{font-weight:500}
.compare-table thead th{font-size:.9rem;color:var(--primary-light);padding-bottom:1rem}
.compare-table thead th:first-child{color:var(--text-muted)}
.check{color:var(--success)}
.dash{color:var(--text-muted)}

/* ── Badge ────────────────────────────────────────────── */
.powered-by{text-align:center;padding:2rem;color:var(--text-muted);font-size:.85rem;display:flex;align-items:center;justify-content:center;gap:.5rem}
.powered-by strong{color:var(--text)}

/* ── FAQ ───────────────────────────────────────────────── */
.faq{max-width:780px;margin:0 auto;padding:0 2rem 5rem}
.faq h2{text-align:center;font-size:1.8rem;font-weight:700;margin-bottom:2.5rem}
.faq-item{border-bottom:1px solid var(--border-dark)}
.faq-q{width:100%;background:none;border:none;color:var(--text);font-size:1rem;font-weight:600;text-align:left;padding:1.25rem 0;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-family:inherit}
.faq-q::after{content:'+';font-size:1.4rem;color:var(--primary-light);transition:transform .3s}
.faq-item.open .faq-q::after{transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .35s ease;color:var(--text-muted);font-size:.92rem;line-height:1.7}
.faq-item.open .faq-a{max-height:300px;padding-bottom:1.25rem}

/* ── Footer ────────────────────────────────────────────── */
.footer{border-top:1px solid var(--border-dark);padding:3rem 2rem;text-align:center}
.footer-inner{max-width:1200px;margin:0 auto}
.footer p{color:var(--text-muted);font-size:.82rem}

/* ── Modal ─────────────────────────────────────────────── */
.modal-overlay{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.6);backdrop-filter:blur(4px);display:none;align-items:center;justify-content:center;padding:2rem}
.modal-overlay.visible{display:flex}
.modal{background:var(--bg-card);border-radius:var(--radius-lg);padding:2.5rem;max-width:500px;width:100%;max-height:90vh;overflow-y:auto;color:var(--text-dark);position:relative;box-shadow:var(--shadow-xl)}
.modal-wide{max-width:720px}
.modal-close{position:absolute;top:1rem;right:1rem;background:none;border:none;font-size:1.5rem;cursor:pointer;color:var(--text-secondary);line-height:1}
.modal h2{font-size:1.4rem;font-weight:700;margin-bottom:.5rem}
.modal-sub{color:var(--text-secondary);font-size:.9rem;margin-bottom:1.5rem}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:.75rem}
.form-group{display:flex;flex-direction:column;gap:.3rem;margin-bottom:.75rem}
.form-group label{font-size:.8rem;font-weight:600;color:var(--text-secondary)}
.form-group input,.form-group textarea,.form-group select{padding:.65rem .75rem;border:1px solid var(--border);border-radius:8px;font-size:.9rem;font-family:inherit;transition:border-color .2s;outline:none}
.form-group input:focus,.form-group textarea:focus{border-color:var(--primary)}
.form-group textarea{resize:vertical;min-height:70px}
.form-submit{margin-top:1rem}
.form-submit .btn{width:100%;padding:.8rem}

/* ── Auth Tabs ─────────────────────────────────────────── */
.auth-tabs{display:flex;border-bottom:2px solid var(--border);margin-bottom:1.5rem}
.auth-tab{flex:1;padding:.75rem;text-align:center;font-size:.9rem;font-weight:600;color:var(--text-secondary);background:none;border:none;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .2s;font-family:inherit}
.auth-tab.active{color:var(--primary);border-bottom-color:var(--primary)}
.auth-tab:hover:not(.active){color:var(--text-dark)}
.auth-view{display:none}
.auth-view.active{display:block}
.auth-divider{display:flex;align-items:center;gap:1rem;margin:1.25rem 0;color:var(--text-muted);font-size:.8rem}
.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:var(--border)}
.form-error{background:#FEF2F2;border:1px solid #FECACA;color:#991B1B;padding:.6rem .75rem;border-radius:8px;font-size:.85rem;margin-bottom:1rem;display:none}
.form-error.visible{display:block}
.password-field{position:relative}
.password-toggle{position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-secondary);font-size:.85rem;padding:2px 4px}

/* ── Stepper ───────────────────────────────────────────── */
.stepper{display:flex;justify-content:space-between;margin-bottom:2rem;position:relative}
.stepper::before{content:'';position:absolute;top:18px;left:10%;right:10%;height:2px;background:var(--border);z-index:0}
.step{display:flex;flex-direction:column;align-items:center;gap:.4rem;position:relative;z-index:1;flex:1}
.step-num{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.85rem;font-weight:700;background:var(--border);color:var(--text-secondary);transition:all .3s}
.step.active .step-num{background:var(--primary);color:#fff}
.step.done .step-num{background:var(--success);color:#fff}
.step-label{font-size:.7rem;font-weight:600;color:var(--text-muted);text-align:center;max-width:90px}
.step.active .step-label{color:var(--primary)}
.step-content{min-height:300px}

/* ── Toast ─────────────────────────────────────────────── */
.toast{position:fixed;top:80px;right:2rem;z-index:300;background:#065F46;color:#fff;padding:1rem 1.5rem;border-radius:10px;box-shadow:var(--shadow-lg);display:none;align-items:center;gap:.75rem;font-size:.9rem;max-width:400px}
.toast.visible{display:flex}
.toast.error{background:#991B1B}

/* ── Utilities ─────────────────────────────────────────── */
.text-center{text-align:center}
.mt-1{margin-top:1rem}
.mt-2{margin-top:2rem}
.spinner{display:inline-block;width:18px;height:18px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .6s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.hidden{display:none!important}
</style>
</head>
<body>

<!-- ═══ NAV ═══ -->
<nav class="nav">
  <div class="nav-inner">
    <div class="logo"><span>NovaSpark</span>&nbsp;AI</div>
    <ul class="nav-links">
      <li><a href="#">Platform</a></li>
      <li><a href="#">Solutions</a></li>
      <li><a href="#">Resources</a></li>
      <li><a href="#" style="color:#fff;font-weight:600">Pricing</a></li>
    </ul>
    <div class="nav-cta" id="navCtaGuest">
      <button class="btn-sm btn-ghost" onclick="openAuthModal('login')">Log In</button>
      <button class="btn-sm btn-accent-sm" onclick="openAuthModal('register','trial')">Start Free Trial</button>
    </div>
    <div class="nav-cta hidden" id="navCtaUser">
      <div class="nav-user">
        <button class="btn-sm btn-ghost" onclick="openDashboard()" style="font-weight:600;color:var(--primary)">My Dashboard</button>
        <span class="nav-user-name" id="navUserName"></span>
        <div class="nav-user-avatar" id="navUserAvatar"></div>
        <button class="btn-sm btn-ghost" onclick="logoutUser()">Log Out</button>
      </div>
    </div>
  </div>
</nav>

<!-- ═══ HERO ═══ -->
<section class="hero">
  <h1>Create Better Content, <em>Faster</em></h1>
  <p>Plans and pricing designed to scale with you &mdash; from solo creators to enterprise teams.</p>

  <div class="toggle-wrap">
    <span class="toggle-label active" data-cycle="monthly" onclick="setBilling('monthly')">Monthly</span>
    <span class="toggle-label" data-cycle="annual" onclick="setBilling('annual')">
      Annual <span class="toggle-badge">Save 20%</span>
    </span>
  </div>

  <div class="api-badge api-badge-dark">Flexible plans for every team</div>
</section>

<!-- ═══ PRICING CARDS ═══ -->
<section class="pricing-section">
  <div class="pricing-grid">

    <!-- ── Starter ── -->
    <div class="card" id="card-starter">
      <div class="card-icon">&#x1F331;</div>
      <h3>Starter</h3>
      <div class="price">
        <span class="currency">$</span>
        <span class="amount" data-monthly="39" data-annual="29">29</span>
        <span class="period">/ month per seat</span>
      </div>
      <p class="card-desc">For individuals getting started with AI-powered content creation.</p>
      <button class="btn btn-outline" id="btnStarter" onclick="handlePlanAction('trial','Starter')">Start Free 14-Day Trial</button>
      <hr/>
      <div class="feature-heading">Plan includes:</div>
      <ul class="feature-list">
        <li>1 seat included</li>
        <li>AI content generation</li>
        <li>1 Brand Voice</li>
        <li>3 Knowledge Assets</li>
        <li>50+ templates</li>
        <li>Email support</li>
      </ul>
    </div>

    <!-- ── Pro (Featured) ── -->
    <div class="card featured" id="card-pro">
      <div class="popular-badge">MOST POPULAR</div>
      <div class="card-icon">&#x26A1;</div>
      <h3>Pro</h3>
      <div class="price">
        <span class="currency">$</span>
        <span class="amount" data-monthly="79" data-annual="59">59</span>
        <span class="period">/ month per seat</span>
      </div>
      <p class="card-desc">For growing teams that need advanced AI content tools and collaboration.</p>
      <button class="btn btn-primary" id="btnPro" onclick="handlePlanAction('trial','Pro')">Start Free 14-Day Trial</button>
      <hr/>
      <div class="feature-heading">Everything in Starter, plus:</div>
      <ul class="feature-list">
        <li>Up to 10 seats</li>
        <li>5 Brand Voices</li>
        <li>25 Knowledge Assets</li>
        <li>100+ templates</li>
        <li>AI image generation</li>
        <li>API access</li>
        <li>Priority support</li>
      </ul>
    </div>

    <!-- ── Enterprise ── -->
    <div class="card" id="card-enterprise">
      <div class="card-icon">&#x1F3E2;</div>
      <h3>Enterprise</h3>
      <div class="price price-custom">
        <span class="amount">Custom</span>
        <span class="period">&nbsp;pricing</span>
      </div>
      <p class="card-desc">Full platform with dedicated support, custom SLAs, and advanced security.</p>
      <button class="btn btn-accent" onclick="handlePlanAction('quote','Enterprise')">Contact Sales</button>
      <hr/>
      <div class="feature-heading">Everything in Pro, plus:</div>
      <ul class="feature-list">
        <li>Unlimited seats</li>
        <li>Unlimited Brand Voices</li>
        <li>Unlimited Knowledge Assets</li>
        <li>Custom workflows &amp; agents</li>
        <li>Multi-currency &amp; tax</li>
        <li>SSO &amp; SCIM</li>
        <li>Dedicated CSM</li>
        <li>24/7 SLA support</li>
      </ul>
    </div>

  </div>
</section>

<!-- ═══ POWERED BY ═══ -->
<div class="powered-by">
  &#x1F512; Secured checkout &amp; billing
</div>

<!-- ═══ FEATURE COMPARISON ═══ -->
<section class="comparison">
  <h2>Compare Plans</h2>
  <table class="compare-table">
    <thead>
      <tr><th>Feature</th><th>Starter</th><th>Pro</th><th>Enterprise</th></tr>
    </thead>
    <tbody>
      <tr><td>AI Content Generation</td><td class="check">&#10003;</td><td class="check">&#10003;</td><td class="check">&#10003;</td></tr>
      <tr><td>Brand Voices</td><td>1</td><td>5</td><td>Unlimited</td></tr>
      <tr><td>Knowledge Assets</td><td>3</td><td>25</td><td>Unlimited</td></tr>
      <tr><td>Team Seats</td><td>1</td><td>Up to 10</td><td>Unlimited</td></tr>
      <tr><td>Templates</td><td>50+</td><td>100+</td><td>Custom</td></tr>
      <tr><td>AI Image Generation</td><td class="dash">&mdash;</td><td class="check">&#10003;</td><td class="check">&#10003;</td></tr>
      <tr><td>API Access</td><td class="dash">&mdash;</td><td class="check">&#10003;</td><td class="check">&#10003;</td></tr>
      <tr><td>Custom Workflows</td><td class="dash">&mdash;</td><td class="dash">&mdash;</td><td class="check">&#10003;</td></tr>
      <tr><td>SSO &amp; SCIM</td><td class="dash">&mdash;</td><td class="dash">&mdash;</td><td class="check">&#10003;</td></tr>
      <tr><td>Dedicated CSM</td><td class="dash">&mdash;</td><td class="dash">&mdash;</td><td class="check">&#10003;</td></tr>
      <tr><td>SLA</td><td class="dash">&mdash;</td><td class="dash">&mdash;</td><td class="check">&#10003;</td></tr>
      <tr><td>Support</td><td>Email</td><td>Priority</td><td>24/7 Dedicated</td></tr>
    </tbody>
  </table>
</section>

<!-- ═══ FAQ ═══ -->
<section class="faq">
  <h2>Frequently Asked Questions</h2>

  <div class="faq-item">
    <button class="faq-q" onclick="toggleFaq(this)">How much does NovaSpark cost?</button>
    <div class="faq-a">NovaSpark offers three plans: Starter at $29/mo (annual) or $39/mo (monthly), Pro at $59/mo (annual) or $79/mo (monthly), and Enterprise with custom pricing. All plans include a 14-day free trial.</div>
  </div>
  <div class="faq-item">
    <button class="faq-q" onclick="toggleFaq(this)">Can I try NovaSpark for free?</button>
    <div class="faq-a">Yes! Both our Starter and Pro plans offer a 14-day free trial with no credit card required. You can upgrade to a paid plan at any time during or after your trial.</div>
  </div>
  <div class="faq-item">
    <button class="faq-q" onclick="toggleFaq(this)">How does the free trial to paid conversion work?</button>
    <div class="faq-a">During your trial, you can upgrade anytime through the in-app upgrade flow. The system will calculate real-time pricing, process your payment, and generate an invoice &mdash; all in a seamless 5-step process.</div>
  </div>
  <div class="faq-item">
    <button class="faq-q" onclick="toggleFaq(this)">What happens when I click Contact Sales?</button>
    <div class="faq-a">A quote is automatically generated in our system and the assigned sales representative is immediately notified. They will reach out to you within 24 hours to discuss your requirements and provide a customized proposal.</div>
  </div>
  <div class="faq-item">
    <button class="faq-q" onclick="toggleFaq(this)">What payment methods do you accept?</button>
