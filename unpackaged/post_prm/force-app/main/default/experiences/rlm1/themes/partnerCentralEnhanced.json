{
  "activeBrandingSetId": "231c09da-8cfd-4a36-91d2-d32d54ce26e2",
  "customCSS": "/* -------------- Dreamforce 25 - PEM Quick Nav Menu CSS overrides -------------- */\n\n\t.quick-links {\n      \t\tdisplay: flex;\n      \t\tjustify-content: center;\n     \t\t gap: 20px;\n      \t\tmargin-top: 30px;\n    \t}\n\n\t.quick-link {\n      /* background-color: #2D2D2D; /* dark blue */\n      background-color: #081534;\n      color: white;\n      text-align: center;\n      padding: 40px 30px;\n      border-radius: 20px;\n      width: 200px;\n      text-decoration: none;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      transition: transform 0.2s ease;\n    }\n    .quick-link:hover {\n      transform: scale(1.05);\n    }\n    .quick-link img {\n      width: 40px;\n      height: 40px;\n      margin-bottom: 20px;\n    }\n    .quick-link span {\n      font-weight: bold;\n      font-size: 16px;\n    }\n\n    .link-card {\n      background-color: #081534;\n      color:white !important;\n      padding: 20px 25px;\n      border-radius: 12px;\n      width: 150px;\n      box-shadow: 0 4px 8px rgba(0,0,0,0.2);\n      transition: transform 0.2s;\n      cursor: pointer;\n    }\n\n    .link-card:hover {\n      transform: translateY(-5px);\n    }\n\n    .link-icon {\n      font-size: 28px;\n      margin-bottom: 10px;\n    }\n\n    .link-text {\n      font-size: 16px;\n    }\n\n/* --- Pipeline Inspection --- */\n.runtime_pipeline_inspectorPipelineInspectorHomeExperienceContainer .commonListContainer {\n min-height: 575px !important;}\n\n/* Target the specific SLDS icon button classes */\n.slds-button_icon-border, \n.slds-button_icon-border-filled {\n    /* Override the custom variables used by the system */\n  \n    \n    /* Fallback for standard SLDS height/width */\n    width: 1.5rem !important;\n    height: 1.5rem !important;\n    line-height: 1 !important;\n}",
