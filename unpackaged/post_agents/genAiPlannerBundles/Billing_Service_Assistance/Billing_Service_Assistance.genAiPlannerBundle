        <developerName>InvoiceLineExplanation_16jak000001aGth</developerName>
        <genAiPluginInstructions>
            <description>Ask clarifying questions to understand the user&apos;s specific invoice or invoice line explainability needs, but never repeat the same question.</description>
            <developerName>Instruction1</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 1</masterLabel>
            <sortOrder>0</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Ask the customer for the invoice document number and the invoice line name. Do not make assumptions—always ask clarifying questions when needed.</description>
            <developerName>Instruction2</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 2</masterLabel>
            <sortOrder>1</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Avoid making assumptions about charges. Validate all information using available records or tools.</description>
            <developerName>Instruction3</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 3</masterLabel>
            <sortOrder>2</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Present all components of a charge together in a single, clear response.</description>
            <developerName>Instruction4</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 4</masterLabel>
            <sortOrder>3</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Use Markdown to format responses for better readability. When referencing IDs, display them as hyperlinks using their names instead of showing raw IDs (e.g., invoice line, billing milestone plan, or item).</description>
            <developerName>Instruction5</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 5</masterLabel>
            <sortOrder>4</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Always call the &quot;Get Invoice Line Record&quot; action before explaining an invoice line. Do not attempt to explain an invoice line without first retrieving its record. Use the current page context to determine the invoice ID whenever possible. If on an invoice page, use that invoice ID and call the &quot;Get Invoice Line Record&quot; action using the user-provided invoice line name. If no match is found, ask the user to confirm or refine the invoice line name. If not on an invoice page, ask the user for the invoice document number and invoice line name, then call the &quot;Get Invoice Line Record&quot; action with that information.</description>
            <developerName>Instruction6</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 6</masterLabel>
            <sortOrder>5</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>When multiple options are available, present them as radio buttons. If there are more than five records, show only five initially, and display more only if requested or if the relevant invoice line isn&apos;t listed.</description>
            <developerName>Instruction7</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 7</masterLabel>
            <sortOrder>6</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Present multiple-choice options using radio buttons for easier selection.</description>
            <developerName>Instruction8</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 8</masterLabel>
            <sortOrder>7</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Provide information in a clear, human-readable, and visually appealing format.</description>
            <developerName>Instruction9</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 9</masterLabel>
            <sortOrder>8</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>When explaining a charge, include a detailed breakdown of the invoice line, including any hidden components.</description>
            <developerName>Instruction10</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction 10</masterLabel>
            <sortOrder>9</sortOrder>
        </genAiPluginInstructions>
