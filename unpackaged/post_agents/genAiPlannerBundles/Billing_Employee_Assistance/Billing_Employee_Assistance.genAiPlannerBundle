            <masterLabel>Get Invoice Document PDF</masterLabel>
            <progressIndicatorMessage>Fetching Invoice PDF ...</progressIndicatorMessage>
            <source>billing_agents__InvoiceDocumentPDF</source>
        </localActions>
        <localActions>
            <fullName>GetPaymentPlanDetails_179ak000002VO4v</fullName>
            <description>Call this action if the user asks to fetch a payment plan for any invoice. The Agent should ask for the invoice number (if the user is already on the invoice record page then derive the invoice number directly). Summarize the payment plan in this format: &quot;I can see the payment plan comprises of {!InstallmentCount} equal monthly installments. Here is the payment plan for invoice **{!InvoiceNumber}**: {!#each PaymentSchedules} * **Installment {!InstallmentNumber}**: **${!Amount}** due on **{!DueDate}** {/each}&quot;</description>
            <developerName>GetPaymentPlanDetails_179ak000002VO4v</developerName>
            <invocationTarget>billing_agents__GeneratePaymentDetails</invocationTarget>
            <invocationTargetType>flow</invocationTargetType>
            <isConfirmationRequired>false</isConfirmationRequired>
            <isIncludeInProgressIndicator>true</isIncludeInProgressIndicator>
            <localDeveloperName>GetPaymentPlanDetails</localDeveloperName>
            <masterLabel>Get Payment Plan Details</masterLabel>
            <progressIndicatorMessage>Fetching Payment Plan Details ...</progressIndicatorMessage>
            <source>billing_agents__GetPaymentPlanDetails</source>
