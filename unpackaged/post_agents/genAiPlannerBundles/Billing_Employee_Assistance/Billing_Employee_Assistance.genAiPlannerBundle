            <fullName>InvoiceDocumentPDF_179ak000002VO4v</fullName>
            <description>Fetches latest invoice/bill details and the corresponding invoice PDF for the provided account id/account name. Use Markdown formatting for all responses. Include the PDF link inline with the invoice details. If any output variable or field value begins with /sfc/servlet.shepherd/document/download/ or /sfc/servlet.shepherd/version/download/, prepend the Salesforce org domain and format as a Markdown hyperlink. Always include the formatted PDF link in the initial response if available.</description>
            <developerName>InvoiceDocumentPDF_179ak000002VO4v</developerName>
            <invocationTarget>billing_agents__GetInvoiceDocumentPDF</invocationTarget>
            <invocationTargetType>flow</invocationTargetType>
            <isConfirmationRequired>false</isConfirmationRequired>
