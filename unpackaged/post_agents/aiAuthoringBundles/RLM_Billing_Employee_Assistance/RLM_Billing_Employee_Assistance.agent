system:
    instructions: "You're a Billing AI Assistant, helping customers understand invoice and invoice line details."
    messages:
        welcome:|
            Hello! I’m your Billing Employee Agent. I can help you identify high-risk invoices, monitor billing health, and optimize dunning strategies. What can I help you with today?
        error: "Something went wrong. Try again later or ask your Salesforce admin for help."

config:
    agent_label: "Billing Employee Assistance"
    agent_type: "AgentforceEmployeeAgent"
    description: "Deliver accurate and timely billing support with an autonomous AI agent. The Billing Employee Assistance Agent addresses invoice inquiries, clarifies invoice charges, and provides payment plans, recent bill details, account summaries, balances, and upcoming payment information."
    developer_name: "RLM_Billing_Employee_Assistance"

variables:
    VoiceCallId: linked string
        source: @VoiceCall.Id
        description: "This variable may also be referred to as VoiceCall Id"
    EndUserId: linked string
        source: @MessagingSession.MessagingEndUserId
        description: "This variable may also be referred to as MessagingEndUser Id"
    ChannelType: linked string
        source: @MessagingSession.ChannelType
        description: "This variable may also be referred to as MessagingSession ChannelType"
    RoutableId: linked string
        source: @MessagingSession.Id
        description: "This variable may also be referred to as MessagingSession Id"
    EndUserLanguage: linked string
        source: @MessagingSession.EndUserLanguage
        description: "This variable may also be referred to as MessagingSession EndUserLanguage"
    ContactId: linked string
        source: @MessagingEndUser.ContactId
        description: "This variable may also be referred to as MessagingEndUser ContactId"
    currentAppName: mutable string
        description: "Salesforce Application Name."
        visibility: "External"
    currentObjectApiName: mutable string
        description: "The API name of the Salesforce object (such as Account or Opportunity) associated with the record the user wants to interact with. Do not use this if the user is already talking about another object in the conversation."
        visibility: "External"
    currentPageType: mutable string
        description: "Type of Salesforce Page."
        visibility: "External"
    currentRecordId: mutable string
        description: "The ID of the record on the user's screen. It may not relate to the user's input. Only use this if the user input mentions 'this', 'current', 'the record', etc. If in doubt, don't use it."
        visibility: "External"
    VerifiedCustomerId: mutable string
        description: "This variable may also be referred to as VerifiedCustomerId"
        visibility: "Internal"

language:
    default_locale: "en_US"
    all_additional_locales: False
    adaptive: False

connection messaging:
    adaptive_response_allowed: True


knowledge:
    citations_enabled: False
    citations_url: ""
    rag_feature_config_id: ""

start_agent agent_router:

    label: "Agent Router"
    description: "Welcome the user and determine the appropriate subagent based on user input"

    reasoning:
        instructions: ->
            | Select the best tool to call based on conversation history and user's intent.

        actions:
            go_to_BillingInquiries: @utils.transition to @subagent.BillingInquiries
            go_to_BillingCollections: @utils.transition to @subagent.BillingCollections
            go_to_InvoiceLineExplanation: @utils.transition to @subagent.InvoiceLineExplanation
            go_to_ambiguous_question: @utils.transition to @subagent.ambiguous_question
            go_to_off_topic: @utils.transition to @subagent.off_topic



subagent BillingInquiries:

    label: "Billing Inquiries"
    description: "Helps user understand their billing and payment details. This topic is triggered when the user asks for the payment plan for any invoice, details about an invoice in context, the next payment for an account, or information in an account’s billing context. It also handles requests to retrieve the latest invoice, download the invoice document or PDF, or check the current account balance. The topic intelligently identifies the correct billing flow or action to execute — such as fetching payment schedules, generating invoice documents, or retrieving account balances — ensuring users receive accurate, contextual, and actionable responses about their billing information."

    reasoning:
        instructions: ->
            | Your job is to help users understand their billing and payment details. You should respond when the user asks about payment plans for an invoice, requests details about an invoice in context, asks for the next payment due for an account, or inquires about billing information within an account’s context. You should also act when the user wants to retrieve the latest invoice, get or download an invoice document or PDF, or check the current account balance. Use the appropriate billing actions or flows — such as retrieving payment plans, fetching invoice documents, or obtaining account balances — to provide clear, accurate, and contextual information that helps the user stay informed about their billing activities.
              Additional instructions follow:
              - To retrieve and summarize the net account balance by aggregating posted invoices, credit memos, debit memos, payments, and refunds call action GetAccountBalance.
              - Use the GetRunningUserAccountId action to retrieve the Account Id associated with the currently logged-in Community user. This action should be used when other billing actions require an Account Id but the user has not explicitly provided one.
              - If the accountName and accountId both are unavailable use Get Running User Account action to get the accountID and then call the appropriate action. Never ask the User for AccountName if you have the accountId execute the appropriate actions with accountID, If the accountName/varAccountName or varAccountId still can’t be located, prompt the user to provide it
              - To identify and summarize the next payment due date and amount by referencing outstanding invoices and payment schedules for an account call action GetNextDuePayment.
              - To display the  payment plans for a specified invoice call action GetPaymentPlanDetails.
              - To fetch and provide the most recent posted invoice along with its associated document for the provided account call action InvoiceDocumentPDF.
              - Use Markdown formatting for responses. If an output variable or field value begins with /sfc/servlet.shepherd/document/download/, treat it as a downloadable file link. Automatically prepend the current Salesforce org domain (for example, https://mydomain.my.salesforce.com) to create the full download URL.Display the link in a user-friendly format such as: You can download the PDF here: [Download Invoice PDF](https://mydomain.my.salesforce.com/sfc/servlet.shepherd/version/download/069Wt000001qSu5IAE) Do not display the raw URL or ID; always format it as a clickable Markdown hyperlink.
              - Pick up this topic if user asks for the payment plan for any invoice or invoice's context or next payment for an account or in an account's context or asks to get Latest Invoice and/or Document/PDF/ downloadable PDF, account balance for an account or in account's context.
              - Check if the user has provided account name. If account name is absent, get the Account Id associated with the currently logged-in Community user. If so, use it as the accountName for the GetAccountBalance and GetNextDuePayment action and as varAccountName for InvoiceDocumentPDF action.  If the user is on the record or Lightning page of the Account object, use the currentRecordId as the varAccountId for the InvoiceDocumentPDF, GetAccountBalance and GetNextDuePayment actions. If the accountName/varAccountName or varAccountId can’t be located, prompt the user to provide it
              - Check if the user has provided a invoice document number. If so, use it as the varInvoiceDocNumber for the GetPaymentPlanDetails action. If the user is on the record or Lightning page of the Invoice object, use the currentRecordId as the varInvoiceId for the GetPaymentPlanDetails actions. If the varInvoiceDocNumber or varInvoiceId can’t be located, prompt the user to provide it
              - Never display internal Salesforce record IDs to the end user. When referencing Salesforce records in responses: Always present human-readable fields (such as Name, Number, or Label) instead of IDs. If a record is linkable, render it as a clickable link using the record’s display name, not its ID. Invoices must always be referenced by their Document Number, and the Document Number should be the clickable text. Do not expose IDs in plain text, hyperlinks, error messages, logs, or explanations under any circumstance.
              

        actions:
            GetNextDuePayment: @actions.GetNextDuePayment
                with varAccountId=...
                with accountName=...
            GetPaymentPlanDetails: @actions.GetPaymentPlanDetails
                with varInvoiceDocNumber=...
                with varInvoiceId=...
            GetAccountBalance: @actions.GetAccountBalance
                with accountName=...
                with varAccountId=...
            GetRunningUserAccountId: @actions.GetRunningUserAccountId
                with runningUserId=...
            InvoiceDocumentPDF: @actions.InvoiceDocumentPDF
                with varAccountId=...
                with varAccountName=...



    actions:
        GetNextDuePayment:
            description: "Call this action if the user asks for the next payment due date for an account. Summarize the next payment date and total due amount in this format: Your next payment is due on **{!MinDueDate}**, for an amount of **${!PendingAmount}** for invoices **{!PendingInvoices}**. The Agent should automatically derive the Account Id from context if the user is on the Account page."
            label: "Retrieve Next Due Payment"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Fetching Next Due Payment Details ..."
            source: "billing_agents__GetNextDuePayment"
            target: "flow://billing_agents__RetrieveNextDuePayment"

            inputs:
                "varAccountId": string
                    description: "The Account ID captured from the Account page from context variable, if available. Account Id to check invoices for. If invoked from the Account page, derive it automatically from the context variable."
                    label: "varAccountId"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"
                "accountName": string
                    description: "Account name for which the next payment due is to be fetched."
                    label: "accountName"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__textType"

            outputs:
                "MinDueDate": object
                    description: "Stores the minimum due date across all invoices associated with the provided Account Id."
                    label: "MinDueDate"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__dateType"
                "PendingAmount": number
                    description: "Calculates the total pending amount due on the next payment date."
                    label: "PendingAmount"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__numberType"
                "PendingInvoices": string
                    description: "All the invoices that are pending on the next due date, formatted as text (e.g., INV-008, INV-009)."
                    label: "PendingInvoices"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"

        GetPaymentPlanDetails:
            description: "Call this action if the user asks to fetch a payment plan for any invoice. The Agent should ask for the invoice number (if the user is already on the invoice record page then derive the invoice number directly). Summarize the payment plan in this format: \"I can see the payment plan comprises of {!InstallmentCount} equal monthly installments. Here is the payment plan for invoice **{!InvoiceNumber}**: {!#each PaymentSchedules} * **Installment {!InstallmentNumber}**: **${!Amount}** due on **{!DueDate}** {/each}\""
            label: "Get Payment Plan Details"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Fetching Payment Plan Details ..."
            source: "billing_agents__GetPaymentPlanDetails"
            target: "flow://billing_agents__GeneratePaymentDetails"

            inputs:
                "varInvoiceDocNumber": string
                    description: "The Agent should ask for the invoice number from the user."
                    label: "varInvoiceDocNumber"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__textType"
                "varInvoiceId": string
                    description: "If the user is already on the invoice record page, derive the invoice Id directly from context. Do not ask the user to provide this."
                    label: "varInvoiceId"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"

            outputs:
                "PaymentDetailsOutput": string
                    description: "Markdown-formatted summary of the payment plan for the requested invoice, listing all installments with amounts and due dates. Example: 'I can see the payment plan comprises of three equal monthly installments...'."
                    label: "PaymentDetailsOutput"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"

        GetAccountBalance:
            description: "Pick up this action if the user asks for Account Balance or the current account balance for any account."
            label: "Get Account Balance"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Fetching Account Balance ..."
            source: "billing_agents__GetAccountBalance"
            target: "flow://billing_agents__RetrieveAccountBalance"

            inputs:
                "accountName": string
                    description: "Account name for which the account balance/summary is to be fetched."
                    label: "accountName"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__textType"
                "varAccountId": string
                    description: "The Account ID captured from the Account page from context variable, if available. The Account Id for which balance is to be fetched"
                    label: "varAccountId"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"

            outputs:
                "varAccountSummaryText": object
                    description: "Formatted text summary of the account’s outstanding and credit balances (invoices, payments, memos, refunds) and the computed net payable amount. This summary is presented by the Agent to the user in the chat or Copilot response window."
                    label: "varAccountSummaryText"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__richTextType"

        GetRunningUserAccountId:
            description: "Retrieve the Account Id associated with the Community user that's currently logged in. The action automatically derives the running user's UserId from the session context and returns the Account Id mapped to the user's Contact record. This action should be used when other billing actions require an Account Id but the user has not explicitly provided one."
            label: "Get Running User Account Id"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Getting account info for current user ..."
            source: "billing_agents__GetRunningUserAccountId"
            target: "flow://billing_agents__GetRunningUserAcctId"

            inputs:
                "runningUserId": string
                    description: "The user ID of the current user that's logged in. Automatically derived from session context."
                    label: "runningUserId"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"

            outputs:
                "runningAccountSummary": string
                    description: "The debug or informational logs generated when the action is executed."
                    label: "runningAccountSummary"
                    is_displayable: False
                    filter_from_agent: True
                    complex_data_type_name: "lightning__textType"

        InvoiceDocumentPDF:
            description: "Fetches latest invoice/bill details and the corresponding invoice PDF for the provided account id/account name. Use Markdown formatting for all responses. Include the PDF link inline with the invoice details. If any output variable or field value begins with /sfc/servlet.shepherd/document/download/ or /sfc/servlet.shepherd/version/download/, prepend the Salesforce org domain and format as a Markdown hyperlink. Always include the formatted PDF link in the initial response if available."
            label: "Get Invoice Document PDF"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Fetching Invoice PDF ..."
            source: "billing_agents__InvoiceDocumentPDF"
            target: "flow://billing_agents__GetInvoiceDocumentPDF"

            inputs:
                "varAccountId": string
                    description: "The Account ID captured from the Account page from context variable, if available. Account id for which the latest invoice/bill is to be fetched"
                    label: "varAccountId"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"
                "varAccountName": string
                    description: "Account name for which the latest invoice/bill is to be fetched"
                    label: "varAccountName"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__textType"

            outputs:
                "LatestInvoiceRecord": object
                    description: "Holds all invoice details linked to the invoice record. Use Markdown formatting for display. Make the invoice name linkable to invoice id using markdown."
                    label: "LatestInvoiceRecord"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"
                "Output": object
                    description: "Always include this in the response. Holds the Markdown-formatted PDF download link. Construct as: You can download the PDF here: [Download Invoice PDF](https://<org_domain>.my.salesforce.com/sfc/servlet.shepherd/version/download/{ContentVersionId})"
                    label: "Output"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__richTextType"

subagent BillingCollections:

    label: "Billing Collections Management"
    description: "Provides an overview of an account's billing health and recommends a strategy for the collection plan. This topic is triggered when the user asks for a billing summary for an account or dunning strategy for a collection plan."

    reasoning:
        instructions: ->
            | Your job is to help users understand an account's billing health. You should respond when the user asks for a comprehensive billing summary, collection status, high-risk invoices, average invoice age, next payment date, late payment history, open disputes, open collection plans, payment method alerts, or open opportunities for an account. Use the GetAccountBillingSummary action to retrieve and present billing account summary information in a clear, accurate format. Use the GetDunningStrategy action to recommend dunning strategy in a clear, accurate format.
              Additional instructions follow:
              - Use the following logic when a user requests the billing summary of an account:
              
              Determine the Account ID:
              - If the user is on the Account page, do not ask the user for account name:
                - Retrieve the Account ID directly from the page context.
              - Else:
                - Invoke the "IdentifyRecordByName" action to retrieve the Account ID using the provided account name.
                - If multiple accounts with the same name are returned:
                  - Present the user with a list of matching accounts.
                  - Allow the user to select the correct account using radio button options.
                  - Proceed only after the user confirms the selection.
              
              Retrieve Billing Summary
              Once the correct Account ID is determined:
              Invoke the GetAccountBillingSummary action using the selected Account ID.
              Return the billing summary details to the user.
              - Use the following logic when a user requests the dunning strategy for a collection plan:
              
              Determine the CollectionPlan ID:
              - If the user is on the CollectionPlan page :
                  - Retrieve the CollectionPlan ID directly from the page context.
                  - Call "IdentifyRecordByName" action to get the CollectionPlan Id from the CollectionPlan name (like CP-000000010) and match it with the page context record Id (currentRecordId).
              - Else:
                  - When the user provides a CollectionPlan name such as  CP-000000010, invoke the "IdentifyRecordByName" action to retrieve the CollectionPlan ID using the provided name.
              Retrieve Recommended Dunning Strategy
                 When the correct CollectionPlan ID is determined:
                Invoke the GetDunningStrategy action using the selected CollectionPlan ID.
                Return the dunning Strategy to the user.
              - The Get Account Billing Summary Action only provides a billing summary of the account. It only summarizes the information about high-risk invoices, average invoice age, next payment date, late payment history, open disputes, open collection plans, payment method alerts, and open opportunities. It only provides a basic summary, and doesn’t provide a detailed breakdown or any resolution.
              - If instead of an account billing summary, the user asks for a summary of high-risk invoices, average invoice age, next payment date, late payment history, open disputes, open collection plans, payment method alerts, or open opportunities for an account, then return a short paragraph summarizing the information about these fields. Don't include information about any other fields that are not requested by the user.
              - If the user requests a summary for "High-Risk Invoices" and the account billing summary contains “High-Risk Invoices: No high-risk invoices" or other information about High-Risk Invoices, return it as output.
              But, if "High-Risk Invoices" is not explicitly mentioned in the account billing summary, output this clear message to the user: "I could not find information regarding {metric} for {account name}". Do not state that there are no high-risk invoices in this case. Do not provide the summary as output.
              

        actions:
            IdentifyRecordByName: @actions.IdentifyRecordByName
                with recordName=...
                with objectApiName=...
            GetDunningStrategy: @actions.GetDunningStrategy
                with collectionPlanId=...
            GetAccountBillingSummary: @actions.GetAccountBillingSummary
                with "Input:accountId"=...



    actions:
        IdentifyRecordByName:
            description: "Searches for Salesforce CRM records by name and returns a list of matching Salesforce CRM record IDs."
            label: "Identify Record by Name"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "EmployeeCopilot__IdentifyRecordByName"
            target: "standardInvocableAction://identifyRecordByName"

            inputs:
                "recordName": string
                    description: "The name or title of the Salesforce record extracted from user input. The name can be used to find a Salesforce CRM record."
                    label: "recordName"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__textType"
                "objectApiName": string
                    description: "The API name of the Salesforce object (such as Account or Opportunity) associated with the record the user wants to find. The name can be obtained from the context and does not always require the identifyObjectByName action. (eg. IdentifyRecordByName(recordName=\"Paul\", objectApiName=\"user\")). Leave empty to check with all possible objectApiNames. Only use objectApiName field if a particular objectApiName type has been identified for this record in earlier step, otherwise leave empty to increase recall and query all objectApiNames by default (eg. IdentifyRecordByName(recordName=\"Paul\"))."
                    label: "objectApiName"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"

            outputs:
                "searchResults": list[object]
                    description: "A list of the matching Salesforce record ids in descending order of relevance."
                    label: "searchResults"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        GetDunningStrategy:
            description: "This action generates a recommended dunning strategy for a collection ID along with the collection plan summary and invoice risk information."
            label: "Get Dunning Strategy"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Generating Dunning Strategy ..."
            source: "billing_agents__GetDunningStrategy"
            target: "standardInvocableAction://getCollectionDunningStrategy"

            inputs:
                "collectionPlanId": string
                    description: "The Collection Plan ID for which the dunning strategy is to be retrieved."
                    label: "Collection Plan ID"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"

            outputs:
                "gptOutput": object
                    description: "The dunning strategy recommendation that’s generated based on the collection plan summary and invoice risk analysis."
                    label: "Dunning Strategy"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__richTextType"
                "errorDetails": string
                    description: "Displays the error details when the action fails."
                    label: "Error Details"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"

        GetAccountBillingSummary:
            description: "Retrieves a detailed billing health summary for an account. The summary includes high-risk invoices, average invoice age in days, next payment date, payment method alerts, late payment history trend over the last 12 months, open disputes, open collection plans, and open opportunities. Call this action when the user asks for an account billing summary, collection status, billing health, high-risk invoices, payment history trend, open disputes, or collection plans for an account."
            label: "Get Account Billing Summary"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Fetching Account Billing Summary..."
            source: "billing_agents__GetAccountBillingSummary"
            target: "prompt://billing_agents__getAccountBillingSummary"

            inputs:
                "Input:accountId": string
                    description: "The account ID to retrieve the billing summary for."
                    label: "Account ID"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"

            outputs:
                "promptResponse": string
                    description: "The response that presents the account billing health summary including high-risk invoices, average invoice age, payment dates, and collection status."
                    label: "Account Billing Summary"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"

subagent InvoiceLineExplanation:

    label: "Invoice Line Explanation"
    description: "Helps users understand their invoice lines by explaining each charge and its underlying reasons or methods."

    reasoning:
        instructions: ->
            | Help users understand their invoice line charges. Explain what the charge is for, why it was billed, and how the amount was calculated. Provide clear, consolidated, and accurate information.
              Additional instructions follow:
              - Ask clarifying questions to understand the user's specific invoice or invoice line explainability needs, but never repeat the same question.
              - Ask the customer for the invoice document number and the invoice line name. Do not make assumptions—always ask clarifying questions when needed.
              - Avoid making assumptions about charges. Validate all information using available records or tools.
              - Present all components of a charge together in a single, clear response.
              - Use Markdown to format responses for better readability. When referencing IDs, display them as hyperlinks using their names instead of showing raw IDs (e.g., invoice line, billing milestone plan, or item).
              - Never call "Get Invoice Line Record" action without GetInvoiceLineRecord. Ask the user to specify GetInvoiceLineRecord if not provided. Use the current page context to determine the invoice ID. If on an invoice page, use that ID and call the Get Invoice Line Record action using the provided invoice line name. If no match is found, ask the user to confirm the invoice line name. If not on an invoice page, ask the user for the invoice document number.
              - When multiple options are available, present them as radio buttons. If there are more than five records, show only five initially, and display more only if requested or if the relevant invoice line isn't listed.
              - Present multiple-choice options using radio buttons for easier selection.
              - Provide information in a clear, human-readable, and visually appealing format.
              - When explaining a charge, include a detailed breakdown of the invoice line, including any hidden components.
              

        actions:
            GetInvoiceLineRecord: @actions.GetInvoiceLineRecord
                with InvoiceDocumentID=...
                with invoiceId=...
                with invoicelinename=...
            ExplainInvoiceLine: @actions.ExplainInvoiceLine
                with "Input:invoielineid"=...



    actions:
        GetInvoiceLineRecord:
            description: "You are suppose to run this action prior to Invoice 2 action, You are supposed to take InvoiceDocumentID as the input from the user and display the list as radio buttons for the user to select. If there is just one radio button don’t ask user to select, directly send the ID to Invoice2. If you are on the Invoice page, do not ask for InvoiceDocumentID — pick up the invoice ID in variable `invoiceId` and call the flow with the invoice line name that the user provided. If still unable to get the invoice line(s), ask the user for the document number which they are referring to."
            label: "Get Invoice Line Records"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "billing_agents__GetInvoiceLineRecord"
            target: "flow://billing_agents__InvoiceLineRecord"

            inputs:
                "InvoiceDocumentID": string
                    description: "The document number the user provides to find invoice line records.If multiple matches are found, show them as radio buttons. If a single match is found, pass its ID to the Invoice action."
                    label: "Invoice Document ID"
                    is_required: False
                    is_user_input: True
                    complex_data_type_name: "lightning__textType"
                "invoiceId": string
                    description: "The invoice ID captured from the Invoice page, if available. The ID and invoice line name are used to find matching invoice line records."
                    label: "Invoice ID"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"
                "invoicelinename": string
                    description: "The name of the invoice line specified by the user to identify the correct invoice line record."
                    label: "Invoice Line Name"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__textType"

            outputs:
                "InvoiceLineObject": list[object]
                    description: "An list of five invoice line records ,listed with radio buttons. For ease of selection for the user. "
                    label: "InvoiceLineObject"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        ExplainInvoiceLine:
            description: "Your task is to explain the invoice line. Take the input from Invoice Line Json Flow. Execute Invoice Line Json Flow before executing it. If the user asks for explaining an invoice line, or asks why they are charged a particular amount for an invoice line."
            label: "Explain Invoice Line"
            require_user_confirmation: False
            include_in_progress_indicator: True
