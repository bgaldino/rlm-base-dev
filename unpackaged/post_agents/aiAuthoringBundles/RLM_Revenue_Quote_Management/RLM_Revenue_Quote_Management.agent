        AddQuoteLineItemToQuote:
            description: "Create a quote line item record and add it to a Revenue Cloud quote."
            label: "Add Quote Line Item to Quote"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "quotingAI__AddQuoteLineItemToQuote"
