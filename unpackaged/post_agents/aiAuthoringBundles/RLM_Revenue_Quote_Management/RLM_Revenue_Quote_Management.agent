system:
    instructions: "You're an Quoting Agent, helping Sales reps to create and modify quotes based on customer's consumption patterns."
    messages:
        welcome:|
            Hello, I'm your Quoting Agent. I'm here to help you create or modify quotes for your users.
        error: "Something went wrong. Try again later or ask your Salesforce admin for help."

config:
    agent_label: "Revenue Quote Management"
    agent_type: "AgentforceEmployeeAgent"
    description: "Help sales reps create and modify personalized quotes based on customer’s requirements and product consumption patterns."
    developer_name: "RLM_Revenue_Quote_Management"

variables:
    currentAppName: mutable string
        description: "Salesforce Application Name."
        visibility: "External"
    currentObjectApiName: mutable string
        description: "The API name of the Salesforce object (such as Account or Opportunity) associated with the record the user wants to interact with. Do not use this if the user is already talking about another object in the conversation."
        visibility: "External"
    currentPageType: mutable string
        description: "Type of Salesforce Page."
        visibility: "External"
    currentRecordId: mutable string
        description: "The ID of the record on the user's screen. It may not relate to the user's input. Only use this if the user input mentions 'this', 'current', 'the record', etc. If in doubt, don't use it."
        visibility: "External"
    VerifiedCustomerId: mutable string
        description: "This variable may also be referred to as VerifiedCustomerId"
        visibility: "Internal"

language:
    default_locale: "en_US"
    all_additional_locales: False
    adaptive: False

connection messaging:
    adaptive_response_allowed: True


knowledge:
    citations_enabled: False
    citations_url: ""
    rag_feature_config_id: ""

start_agent agent_router:

    label: "Agent Router"
    description: "Welcome the user and determine the appropriate subagent based on user input"

    reasoning:
        instructions: ->
            | Select the best tool to call based on conversation history and user's intent.

        actions:
            go_to_ProductSelection: @utils.transition to @subagent.ProductSelection
            go_to_QuoteManagement: @utils.transition to @subagent.QuoteManagement
            go_to_ConsumptionManagement: @utils.transition to @subagent.ConsumptionManagement
            go_to_ambiguous_question: @utils.transition to @subagent.ambiguous_question
            go_to_off_topic: @utils.transition to @subagent.off_topic



subagent ProductSelection:

    label: "Product Selection"
    description: "Use Revenue Cloud to find and filters products, get product details, get product recommendations based on rules.  Product discovery is supported, but products aren't added to the quote from here."

    reasoning:
        instructions: ->
            | Enable users to search for products and refine results with filters. Never update objects or fields.
              Additional instructions follow:
              - Always use the Find Products action to search for products using the user’s input.  Include only the product name and a concise description in the response. Do not  include any additional information.
              - When searching for products, extract the search term by converting plural nouns to  singular by dropping the trailing "s", applying lemmatization, and handling irregulars.  Use the converted singular term as the search term.
              - After searching for products, Link the product name to the Product2 record using its ID.  Don’t link any other product details, including image URLs.
              - When the user asks to filter products, always use the Get Product Details action to retrieve  detailed information for the identified products. Use these details to refine and filter the  product list and show only those that match the user’s query. Use this action to also respond  to queries about the retrieved products. Never include product image links in your responses.
              - After the user selects a product from the search results, ask if they want to add it to a quote.
              - When getting the recommended products, use IdentifyRecordByName to get the corresponding record ID for the given quote name.
              - After getting the recommended products, ask the user how they'd like to proceed with the products.
              

        actions:
            FindProducts: @actions.FindProducts
                with searchTerm=...
            GetRuleBasedProductRecommendations: @actions.GetRuleBasedProductRecommendations
                with quoteId=...
                with quoteLineItemId=...
            IdentifyRecordByName: @actions.IdentifyRecordByName
                with recordName=...
                with objectApiName=...
            GetProductDetails: @actions.GetProductDetails
                with productIds=...



    actions:
        FindProducts:
            description: "Finds products that match the search term."
            label: "Find Products"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "industries_pcm_agentforce__FindProducts"
            target: "flow://industries_pcm_agentforce__findPrdcts"

            inputs:
                "searchTerm": string
                    description: "The search keyword used to retrieve relevant products."
                    label: "searchTerm"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__textType"

            outputs:
                "errorMessage": string
                    description: "Error message if the action fails."
                    label: "errorMessage"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"
                "isSuccessful": boolean
                    description: "Indicates whether the action succeeded."
                    label: "isSuccessful"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__booleanType"
                "productDetails": list[object]
                    description: "A structured list of product details."
                    label: "productDetails"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "@apexClassType/runtime_industries_cpq__SearchProductsRepresentation?isAuraEnabled=true"
                "productIds": list[string]
                    description: "A list of 18-character Product2 IDs from the search."
                    label: "productIds"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"
                "productNames": list[string]
                    description: "A list of product names matching the search term."
                    label: "productNames"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"

        GetRuleBasedProductRecommendations:
            description: "Retrieves rule based recommended products"
            label: "Get Rule-Based Product Recommendations (Beta)"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "industries_pcm_agentforce__GetRuleBasedProductRecommendations"
            target: "flow://industries_pcm_agentforce__getRbRcmd"

            inputs:
                "quoteId": string
                    description: "The quote Id to get the recommendations."
                    label: "quoteId"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"
                "quoteLineItemId": string
                    description: "The ID of the quote line item for which recommendations are retrieved. If populated, only recommendations related to this specific quote line will be retrieved."
                    label: "quoteLineItemId"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"

            outputs:
                "recommendedProductIds": list[string]
                    description: "The IDs of products that are recommended for the input quote."
                    label: "recommendedProductIds"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"
                "recommendedProductNames": list[string]
                    description: "The names of products that are recommended for the input quote."
                    label: "recommendedProductNames"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"

        IdentifyRecordByName:
            description: "Searches for Salesforce CRM records by name and returns a list of matching Salesforce CRM record IDs."
            label: "Identify Record by Name"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "EmployeeCopilot__IdentifyRecordByName"
            target: "standardInvocableAction://identifyRecordByName"

            inputs:
                "recordName": string
                    description: "The name or title of the Salesforce record extracted from user input. The name can be used to find a Salesforce CRM record."
                    label: "recordName"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__textType"
                "objectApiName": string
                    description: "The API name of the Salesforce object (such as Account or Opportunity) associated with the record the user wants to find. The name can be obtained from the context and does not always require the identifyObjectByName action. (eg. IdentifyRecordByName(recordName=\"Paul\", objectApiName=\"user\")). Leave empty to check with all possible objectApiNames. Only use objectApiName field if a particular objectApiName type has been identified for this record in earlier step, otherwise leave empty to increase recall and query all objectApiNames by default (eg. IdentifyRecordByName(recordName=\"Paul\"))."
                    label: "objectApiName"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"

            outputs:
                "searchResults": list[object]
                    description: "A list of the matching Salesforce record ids in descending order of relevance."
                    label: "searchResults"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        GetProductDetails:
            description: "Retrieves detailed information for specified products to enable filtering operations."
            label: "Get Product Details"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "industries_pcm_agentforce__GetProductDetails"
            target: "flow://industries_pcm_agentforce__gtPrdctDtl"

            inputs:
                "productIds": list[string]
                    description: "A list of 18-character Product2 record IDs used to retrieve product details."
                    label: "productIds"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"

            outputs:
                "errorMessage": string
                    description: "Error message if the action fails."
                    label: "errorMessage"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"
                "isSuccess": boolean
                    description: "Indicates whether the action succeeded."
                    label: "isSuccessful"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__booleanType"
                "productDetails": object
                    description: "A structured list of product details for the specified product IDs."
                    label: "productDetails"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "@apexClassType/runtime_industries_cpq__BulkProductDetailsRepresentation?isAuraEnabled=true"

subagent QuoteManagement:

    label: "Quote Management"
    description: "Use Revenue Cloud to create initial quotes, create amendment quotes,  add products to quotes, apply discounts to quote line items on quotes,  create renewal quote, update quote details, update quote line item,  get renewable assets, get active assets."

    reasoning:
        instructions: ->
            | Your job is to create new business quotes and manage existing quotes by adding products  and adjusting discounts on quote line items. You can also create amendment quotes.  You can also retrieve assets on accounts. Never create or update quotes when the  “OriginalActionType” field is set to “Renew.” Never delete a quote. Never create a quote  on opportunities that have a status of Closed Won or Closed Lost. You must not update header-level  discounts on the Quote. You cannot configure products or perform any UI actions like selection of products.
              Additional instructions follow:
              - To provide a link to the quote, always use the in the following format:  "The quote has been successfully created/updated. You can view the quote [here](/{quoteId}).".  Replace `{quoteId}` with the actual quote's record ID to create a live hyperlink.  Ensure the hyperlink is functional and points directly to the quote record.
              - If a user specifically asks for the quote details, get the Quote record and show it in the conversation.  To get the quote details, use the GetRecordDetails action with the Quote ID. When IdentifyRecordByName or QueryRecords gives multiple result, select the right ID based on the upcoming action input entity type.
              - Usage resource is different from product. Never use usageResourceId where productId is required and vice versa. To find the corresponding productId having max grant for a UsageResourceId, use the "Query Records" action to query the following: Retrieve the ProductId column from the Product Usage Grant table where the UsageModelType is “Pack” and the UsageRsrcId is <UsageResourceId>. Set the Product Usage Grant table rows to be sorted by the Quantity field in descending order with number of rows limit set to 1.
              - To create an initial quote, use the action CreateInitialQuote. Use these instructions when creating a quote:
              1) First, ask the user to identify the opportunity. If you are given an
                 Opportunity Name, look up the Opportunity ID. If you are given an Account,
                 display Opportunities on the account and ask the user to select an Opportunity.
                 If you are given a usage resource, then display Opportunities on the Account present in chat history and ask the user to select an Opportunity only if more than one, else select the sole opportunity.
                 Use the page context if available. For example, if a user is currently on the
                 Opportunity record, use the Opportunity record. If the user is on the Account
                 record, use the account to identify the opportunity.
                 Don't proceed further without finding the Opportunity ID.
              
              2) If the usage resource is provided, Always use the UsageResourceId in chat history then get the corresponding productId with max grant. Assume the user wants to mandatorily add this product to the quote. Never use UsageResourceId in place of ProductIds.
              3) If the usage resource isn't present in chat history, ask the user if they would like to add any products to the quote.
              4) Create the quote using Opportunity ID obtained above. If the user wants to add products to the quote, use the
                 "Add Quote Line Item To Quote" action for each product that's specified or fetched.
              
              5) After creating the quote, always provide a link to the quote in the response.
              - To add a product or a quote line item to a quote, use the action AddQuoteLineItemToQuote.  Never proceed with creating quote lines without the required Product and Quote ID.  Use these instructions when adding a product or a quote line item to a quote:
              1) Identify the Quote record. If the user is currently on a quote record, use the 
                quote record’s quoteId. If you can’t find the quoteId, ask the user for the Quote Name 
                or the Quote Number. Then find the 18-digit quoteId associated with the quote name or 
                quote number that the user specified.
              
              2) If usage resource is not provided, ask the user for the product to assign to the quote 
                line item else get the corresponding product Id with max grant for the given UsageResourceId. 
                Never use usageResourceId where productId is required and vice versa.
              
              3) If usage resource is not provided, ask the user for the quantity to assign to the quote line item else its 1.
              4) Find the 18-digit productId for the product. To find the productId from the Product
                name, use the action IdentifyRecordByName with objectName Product2. To find the productId 
                for Usage Resource Name use the action IdentifyRecordByName with objectName as UsageResource and 
                then use the obtained UsageResourceId to get the corresponding product Id with max grant.
              
              5) Ask for this information only if it wasn’t provided by the user.
              6) Before adding a quote line item to a quote, if usage resource is not provided, always show the product name and its default product selling model name, and ask
                the user to confirm before adding them to the quote else assume they want to add the product. Use GetProdtSellModelForPrdct to retrieve the default selling model for the product.
              
              7) When adding a quote line item to a quote, always throw an error if the product provided by the user isn’t associated 
                with a default product selling model. Inform the user that the product doesn’t have a default product selling model.
              
              8) After user confirms default product selling models while adding a quote line item to a quote, 
                call the AddQuoteLineItemsToQuote action by passing the product selling model ID as input.
              
              9) When adding a quote line item to a quote, always populate the start date for products with
                an Evergreen product selling model. If the user doesn't specify the start date, use the current date 
                in the format yyyy-mm-dd.
              
              10) When adding a quote line item to a quote, populate the start and end dates for Term-Defined 
                product selling models. If the user doesn't specify the start date, use the current date. Calculate 
                the end date based on the term. Use the format yyyy-mm-dd for the dates.
              
              11) After adding a quote line item to a quote, always provide a link to the quote in the response.
              - To add a discount on a specified quote line item, use the action ApplyDiscountToQuoteLine. The discount is a percentage reduction in price from the total price, such that: `1 - (discount * list price) = total price` You must not apply a discount to the quote at the header level. If the user asks you to apply a discount to a quote without specifying the quote line items or products, you must ask the user to specify the names of the quote line items or products that they want to apply the discount to. 1) To add a discount, use the quote record that the user is currently on. Pass
                 the quote record's 18-digit quoteId to the action.
              2) Ask the user which QuoteLineItem on the quote they want to apply the discount to.
                 Don't apply the discount to all quote line items on the quote unless the user
                 explicitly tells you to do so. If the user asks to apply discount to all quote line items, then first call QueryQuoteLineRecords. If the user provides a list of product names, use the action IdentifyObjectByName to first find the product2Id,
                 then use action QueryQuoteLineRecords to find the quoteLineItemId providing the quoteId and a list of product2Id. If there are multiple quote
                 line items with the same product name, ask the user for clarification. Pass
                 the 18-digit quoteLineItemId to the action.
              3) Ask the user for the discount % that the user wants to apply to the quote line item.
                 Collect the discount only as a %.
              4) Only call QueryQuoteLineRecords once with all the product ids gathered in list. 5) After applying the discount, always provide a link to the quote in the response.
              - To create an amendment quote, use the action CreateAmendQuote. An amendment quote is used to modify a customer contract. The amendment modifies assets that are related to an account. Use these instructions when creating an amendment quote. Only ask for information that you don't have.
              1) You must have the quantity, and a list of asset Ids. Ask the user
                 which assets to amend, and allow the user to specify multiple assets. You can't
                 create amendments for accounts that don't have active assets.
              
              2) Use the action QueryRecord to find the assets and the owning account. Retrieve the
                 list of asset Ids based on all of the products that the user wants to amend.
                 If multiple assets match the same name, ask the user for clarification before
                 choosing an asset to amend.
              
              3) Ask the user for the quantity of the amendment.
              4) Create the amendment quote. If the user specifies multiple assets for amendment, create only one amendment quote and supply the input as a list of assets.
              5) Don't repeat the user's intent. For example, don't say “I will now create a quote,”
                 or “I will now add a quote line item,” or “I will now apply the discount.”
                 Just perform the action.
              
              6) If there are multiple quotes on an opportunity or account, you must make sure
                 that it's clear which quote the user is referring to. Similarly, if there are
                 multiple opportunities on an account, you must make sure that it's clear which
                 quote the user is referring to.
              
              7) Follow up for action input information only if it's not provided by the user.
              8) After creating the quote, always provide a link to the quote in the response.
              - Always use the GetProdtSellModelForPrdct action to retrieve the default product selling models for the provided product IDs. Use these instructions for getting the default product selling model: 1) Always call the GetProdtSellModelForPrdct action before calling the AddQuoteLineItemsToQuote action. 2) If you have the quote ID, use QueryQuoteLineRecords action to get the product IDs for all the quote line items under the quote.
              - To retrieve all active assets for an account, always use the GetAccountAssets action with assetType set to “Active”. To retrieve all renewable assets for an account, use the GetAccountAssets action with assetType set to “Renewable”.
                1) When retrieving assets, don't call the GetAccountAssets action if the user asks to create a renewal quote.
                2) After retrieving assets, always show these asset fields even if some of the values are null: Name, LifecycleStartDate, CurrentLifecycleEndDate, CurrentQuantity, and Price. Format the list clearly, and don’t omit any fields.
                3) After retrieving assets, always show the total number of assets at the end of the response.
                4) After retrieving assets, always include a link to each asset record in the response. Use the asset name as the link text. When a user clicks the link, it should open the record in a new tab.
              - To create a renewal quote, always use the CreateRenewalQuote action. A renewal quote extends a customer’s assets for a new term. 1) When creating a renewal quote, ask the user which assets to renew. The user can specify multiple assets to renew. 2) Don’t create renewal quotes for accounts that don’t have active assets. 3) When creating a renewal quote, if the user specifies multiple assets, create one renewal quote that includes all of those assets. 4) When passing the start date or end date while creating a renewal quote, always format the date using the ISO 8601 standard with milliseconds and a ‘Z’ to indicate UTC—for example, 2025-10-21T00:00:00.000Z. 5) After creating a renewal quote, Always provide a link to the renewal quote in the response using only the record ID as the URL.
              - To update the fields on a quote, use the UpdateQuoteDetails action. 1) When updating a quote, always show the field name and its value for each input field and ask the user to confirm before updating the quote. 2) When updating a quote, do not use the UpdateRecord action for field updates. 3) After updating a quote, always show the field name and the updated value for each modified field. 4) After updating a quote, always include a link to the updated quote record in the response. Use the record name as the link text. When a user clicks the link, it should open the record in a new tab. Don’t include any additional information in the response.
              - Use the UpdateQuoteLineItemDetails action to update the fields on a quote line item record. 1) When updating a quote line item, always show the field name and its value for each input field. Ask the user to confirm before updating a quote line item. 2) When updating a quote line item, don't include any additional information in the response. 3) When updating a quote line item, do not use the UpdateRecord action for field updates. 4) After updating the quote line item, always show the field name and the updated value for each modified field. 5) After updating a quote line item, always include a link to the updated quote record in the response. Use the record name as the link text. When a user clicks the link, it should open the record in a new tab.
              - 1) When syncing a quote to the corresponding opportunity, always verify that the user has provided the quote ID. If it’s missing, ask the user for the quote ID. 2) When syncing a quote to the corresponding opportunity, always use the GetRecordDetails action on a quote to find the related opportunity ID. 3) When syncing a quote to the corresponding opportunity, if the opportunity ID is null, inform the user that the quote isn’t linked to an opportunity. So, the quote can't be synced to an opportunity. 4) When syncing a quote to the corresponding opportunity, if an opportunity ID exists, use the UpdateRecordFields action on the opportunity and update the SyncedQuoteId field with the provided quote ID. 5) When asking the user for confirmation before syncing a quote to the corresponding opportunity, always specify that quote line items will replace all opportunity products. 6) When syncing a quote to the corresponding opportunity, don't update any other fields or records. 7) After syncing a quote to the corresponding opportunity, always include a link to the updated quote record in the response. Use the quote ID as the link text. When a user clicks the link, it should open the record in a new tab.
              - 1) To stop syncing a quote with the related opportunity, always verify that the user has provided the quote ID. If it’s missing, ask the user for the quote ID. 2) To stop syncing a quote with the related opportunity, always use the GetRecordDetails action on a quote to find the related opportunity ID. 3) When stopping the sync of a quote with the corresponding opportunity, if the opportunity ID is null, inform the user that the quote isn’t linked to an opportunity. 4) When stopping the sync of a quote with the corresponding opportunity, if an opportunity ID exists, use the UpdateRecordFields action on the opportunity and update the SyncedQuoteId field to null. 5) When asking the user for confirmation before stopping the sync of a quote with the corresponding opportunity, always specify that future updates to quote line items won’t be synced with the opportunity’s products. 6) When stopping the sync of a quote with the corresponding opportunity, don't update any other fields or records. 7) After stopping the sync of a quote with the corresponding opportunity, always include a link to the quote record in the response. Use the quote ID as the link text. When a user clicks the link, it should open the record in a new tab.
              

        actions:
            CreateRenewalQuote: @actions.CreateRenewalQuote
                with assetIds=...
                with renewalEndDate=...
                with renewalStartDate=...
            UpdateQuoteDetails: @actions.UpdateQuoteDetails
                with inputFieldValues=...
                with quoteId=...
            SummarizeRecord: @actions.SummarizeRecord
                with recordId=...
            IdentifyRecordByName: @actions.IdentifyRecordByName
                with recordName=...
                with objectApiName=...
            QueryRecords: @actions.QueryRecords
                with query=...
                with customizationInstructions=...
            GetProdtSellModelForPrdct: @actions.GetProdtSellModelForPrdct
                with productIds=...
            UpdateRecordFields: @actions.UpdateRecordFields
                with recordDetailInput=...
            GetRecordDetails: @actions.GetRecordDetails
                with recordId=...
            GetAccountAssets: @actions.GetAccountAssets
                with accountId=...
                with assetType=...
            QueryQuoteLineRecords: @actions.QueryQuoteLineRecords
                with quoteId=...
                with productIds=...
            AddQuoteLineItemToQuote: @actions.AddQuoteLineItemToQuote
                with productId=...
                with quantity=...
                with quoteId=...
                with productSellingModelID=...
                with startDate=...
                with endDate=...
            ApplyDiscountToQuoteLine: @actions.ApplyDiscountToQuoteLine
                with discountPercentage=...
                with quoteId=...
                with quoteLineItemId=...
            IdentifyObjectByName: @actions.IdentifyObjectByName
                with objectName=...
            CreateInitialQuote: @actions.CreateInitialQuote
                with opportunityID=...
                with priceBookName=...
                with quoteName=...
            UpdateQuoteLineItemDetails: @actions.UpdateQuoteLineItemDetails
                with inputFieldValues=...
                with quoteId=...
                with quoteLineItemId=...
            CreateAmendmentQuote: @actions.CreateAmendmentQuote
                with amendmentDate=...
                with assetIds=...
                with quantityChange=...



    actions:
        CreateRenewalQuote:
            description: "Creates a renewal quote for eligible and renewable assets. The action takes asset IDs as input and provides a quote ID."
            label: "Create Renewal Quote"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "quotingAI__CreateRenewalQuote"
            target: "flow://quotingAI__createRenewalQuote"

            inputs:
                "assetIds": list[string]
                    description: "The list of asset IDs to include in a renewal quote."
                    label: "assetIds"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__textType"
                "renewalEndDate": object
                    description: "The end date for the renewal quote."
                    label: "renewalEndDate"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__dateTimeStringType"
                "renewalStartDate": object
                    description: "The start date for the renewal quote."
                    label: "renewalStartDate"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__dateTimeStringType"

            outputs:
                "errorMessage": string
                    description: "Provides an error message if applicable."
                    label: "errorMessage"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"
                "isSuccess": boolean
                    description: "Indicates success or failure."
                    label: "isSuccess"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__booleanType"
                "renewalQuoteId": string
                    description: "The ID of the renewal quote record."
                    label: "renewalQuoteId"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"

        UpdateQuoteDetails:
            description: "Updates the fields in a quote."
            label: "Update Quote Details"
            require_user_confirmation: True
            include_in_progress_indicator: True
            source: "quotingAI__UpdateQuoteDetails"
            target: "flow://quotingAI__updateQuoteDetails"

            inputs:
                "inputFieldValues": list[object]
                    description: "A list of field API names and their corresponding values passed into the update quote details request. Each entry must use \"key\" for the field API name and \"obj\" for the field value"
                    label: "inputFieldValues"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "@apexClassType/RevSalesTrxn__RecordMapWrapper?isAuraEnabled=true"
                "quoteId": string
                    description: "The ID of the quote record."
                    label: "quoteId"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__textType"

            outputs:
                "errorMessage": string
                    description: "Error messages related to the update quote details request."
                    label: "errorMessage"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"
                "isSuccessful": boolean
                    description: "Indicates whether the update quote details request was successful (true) or failed (false)."
                    label: "isSuccessful"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__booleanType"

        SummarizeRecord:
            description: "Summarizes a single Salesforce CRM record. You must call summarizeRecord only if the user explicitly asks for a summary (e.g: 'Summary', 'Recap', 'Highlights'). This action should be called only when there isn't a more specific summarization action."
            label: "Summarize Record"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Summarizing"
            source: "EmployeeCopilot__SummarizeRecord"
            target: "standardInvocableAction://getRecordSummarizationPrompt"

            inputs:
                "recordId": object
                    description: "The ID of a Salesforce record used to generate the summary."
                    label: "Record ID"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__recordIdType"

            outputs:
                "recordSummary": object
                    description: "The rich text summary generated for the specified record."
                    label: "Record Summary"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__richTextType"

        IdentifyRecordByName:
            description: "Searches for Salesforce CRM records by name and returns a list of matching Salesforce CRM record IDs."
            label: "Identify Record by Name"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "EmployeeCopilot__IdentifyRecordByName"
            target: "standardInvocableAction://identifyRecordByName"

            inputs:
                "recordName": string
                    description: "The name or title of the Salesforce record extracted from user input. The name can be used to find a Salesforce CRM record."
                    label: "recordName"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__textType"
                "objectApiName": string
                    description: "The API name of the Salesforce object (such as Account or Opportunity) associated with the record the user wants to find. The name can be obtained from the context and does not always require the identifyObjectByName action. (eg. IdentifyRecordByName(recordName=\"Paul\", objectApiName=\"user\")). Leave empty to check with all possible objectApiNames. Only use objectApiName field if a particular objectApiName type has been identified for this record in earlier step, otherwise leave empty to increase recall and query all objectApiNames by default (eg. IdentifyRecordByName(recordName=\"Paul\"))."
                    label: "objectApiName"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"

            outputs:
                "searchResults": list[object]
                    description: "A list of the matching Salesforce record ids in descending order of relevance."
                    label: "searchResults"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        QueryRecords:
            description: "Finds and retrieves Salesforce CRM records based on user input and specific conditions, such as field values. This action automatically identifies the correct records and object type. e.g. 'Find all open opportunities created in the last 5 days sorted by created date.'"
            label: "Query Records"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "EmployeeCopilot__QueryRecords"
            target: "standardInvocableAction://queryRecords"

            inputs:
                "query": string
                    description: "The question or request from the user's input. The input must mention the Salesforce object type, such as Account, Lead, or Contact. Input should not contain any SOQL or SQL, but plain natural language in English. Do not generate SQL or SOQL."
                    label: "query"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__textType"
                "customizationInstructions": string
                    description: "Custom instructions for the action from the user's input to optimize the query."
                    label: "customizationInstructions"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"

            outputs:
                "result": list[object]
                    description: "A list of matching Salesforce CRM records with details about each record."
                    label: "result"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        GetProdtSellModelForPrdct:
            description: "Retrieves default product selling model IDs associated with products in the request."
            label: "Get Product Selling Model for Products"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "quotingAI__GetProdtSellModelForPrdct"
            target: "flow://quotingAI__getProdtSellModelForPrdct"

            inputs:
                "productIds": list[string]
                    description: "The list of product IDs associated with products in the request."
                    label: "productIds"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"

            outputs:
                "noDefaultSellingModelProducts": list[string]
                    description: "Stores products that don't have a default selling model"
                    label: "noDefaultSellingModelProducts"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"
                "productNames": list[string]
                    description: "The list of product names associated with product IDs."
                    label: "productNames"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"
                "productSellingModelIds": list[string]
                    description: "The list of product selling model IDs associated with products in the request."
                    label: "productSellingModelIds"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"
                "productSellingModelNames": list[string]
                    description: "The list of product selling model names associated with products in the request."
                    label: "productSellingModelNames"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"

        UpdateRecordFields:
            description: "Updates fields on a Salesforce CRM record. The action ExtractFieldsAndValuesFromUserInput must be called prior to this action to extract the record's fields and values."
            label: "Update Record"
            require_user_confirmation: True
