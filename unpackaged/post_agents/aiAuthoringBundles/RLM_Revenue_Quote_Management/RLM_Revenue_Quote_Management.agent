                    label: "errorMessage"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"
                "isSuccessful": boolean
                    description: "Indicates whether the request to get account assets was successful (true) or failed (false)."
                    label: "isSuccessful"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__booleanType"
                "totalAssetCount": number
                    description: "The number of asset IDs retrieved for the account in the request."
                    label: "totalAssetCount"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__numberType"

        QueryQuoteLineRecords:
            description: "Query a list of QuoteLineItem Id when given a list of Product2Id."
            label: "Query Quote Lines (Beta)"
            require_user_confirmation: False
