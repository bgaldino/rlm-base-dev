    <description>This will use Smart Approvals and will also use Agentforce to send the Body of the approval email</description>
    <environments>Default</environments>
    <formulas>
        <name>rejectedQuote</name>
        <dataType>Boolean</dataType>
        <expression>OR(
CONTAINS({!Manager_Approver.Outputs.approvalDecision}, &quot;Reject&quot;),
CONTAINS({!Director_Approver.Outputs.approvalDecision}, &quot;Reject&quot;),
CONTAINS({!VP_Approver.Outputs.approvalDecision}, &quot;Reject&quot;),
CONTAINS({!Payment_Terms.Outputs.approvalDecision}, &quot;Reject&quot;),
CONTAINS({!Margin_Manager.Outputs.approvalDecision}, &quot;Reject&quot;),
CONTAINS({!Margin_Director.Outputs.approvalDecision}, &quot;Reject&quot;),
CONTAINS({!Margin_VP.Outputs.approvalDecision}, &quot;Reject&quot;)
)</expression>
    </formulas>
