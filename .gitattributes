# Default: normalize all text files to LF on commit and checkout
* text=auto eol=lf

# Explicitly LF for files that must stay Unix-style
*.py text eol=lf
*.robot text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.apex text eol=lf
*.cls text eol=lf

# Binaries — no line-ending conversion
*.png binary
*.jpg binary
*.pdf binary
*.zip binary
*.asset binary

# Generated artifacts — collapse in GitHub diff UI and skip from PR review tools.
# Salesforce Help portal snapshots are produced by tasks/rlm_snapshot_help.py;
# review the tooling, not the per-article output.
docs/salesforce/*/help/articles/** linguist-generated=true
docs/salesforce/*/help/manifest.json linguist-generated=true
docs/salesforce/*/help/index.md linguist-generated=true
