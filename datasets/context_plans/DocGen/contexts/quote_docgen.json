    { "nodeName": "Quote", "attributeName": "BillingStreet",    "name": "BillingStreet" },
    { "nodeName": "Quote", "attributeName": "BillingCity",      "name": "BillingCity" },
    { "nodeName": "Quote", "attributeName": "BillingState",     "name": "BillingState" },
    { "nodeName": "Quote", "attributeName": "BillingPostalCode","name": "BillingPostalCode" },
    { "nodeName": "Quote", "attributeName": "SalesRep",         "name": "SalesRep" },
    { "nodeName": "Quote", "attributeName": "QuoteNumber",      "name": "QuoteNumber" },
    { "nodeName": "Quote", "attributeName": "CreatedDate",      "name": "CreatedDate" },
    { "nodeName": "Quote", "attributeName": "ExpirationDate",   "name": "ExpirationDate" },
    { "nodeName": "Quote", "attributeName": "GrandTotal",       "name": "GrandTotal" },
    { "nodeName": "Line",  "attributeName": "ProductName",      "name": "ProductName" },
    { "nodeName": "Line",  "attributeName": "Quantity",         "name": "Quantity" },
    { "nodeName": "Line",  "attributeName": "ListPrice",        "name": "ListPrice" },
    { "nodeName": "Line",  "attributeName": "Discount",         "name": "Discount" },
    { "nodeName": "Line",  "attributeName": "NetUnitPrice",     "name": "NetUnitPrice" },
    { "nodeName": "Line",  "attributeName": "NetTotalPrice",    "name": "NetTotalPrice" }
  ],
  "activate": true
}
