{
  "create": true,
  "developerName": "RLM_QuoteDocGenContext",
  "label": "RLM Quote DocGen Context",
  "description": "Context definition for Quote proposal document generation templates.",
  "primaryDomainObject": "Quote",
  "contextNodeDefinitions": [
    {
      "name": "Quote",
      "label": "Quote"
    },
    {
      "name": "Line",
      "label": "Quote Line Item",
      "parentNodeName": "Quote"
    }
  ],
  "contextMappings": {
    "contextMappings": [
      {
        "name": "QuoteDocGenMapping",
        "description": "QuoteDocGenMapping",
        "isDefault": true
      }
    ]
  },
  "contextAttributesByName": [
    { "nodeName": "Quote", "name": "AccountName",      "dataType": "STRING",   "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Quote", "name": "BillingStreet",    "dataType": "STRING",   "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Quote", "name": "BillingCity",      "dataType": "STRING",   "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Quote", "name": "BillingState",     "dataType": "STRING",   "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Quote", "name": "BillingPostalCode","dataType": "STRING",   "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Quote", "name": "SalesRep",         "dataType": "STRING",   "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Quote", "name": "QuoteNumber",      "dataType": "STRING",   "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Quote", "name": "CreatedDate",      "dataType": "DATE",     "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Quote", "name": "ExpirationDate",   "dataType": "DATE",     "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Quote", "name": "GrandTotal",       "dataType": "CURRENCY", "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Line",  "name": "ProductName",      "dataType": "STRING",   "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Line",  "name": "Quantity",         "dataType": "NUMBER",   "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Line",  "name": "ListPrice",        "dataType": "CURRENCY", "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Line",  "name": "Discount",         "dataType": "PERCENT",  "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Line",  "name": "NetUnitPrice",     "dataType": "CURRENCY", "fieldType": "INPUTOUTPUT" },
    { "nodeName": "Line",  "name": "NetTotalPrice",    "dataType": "CURRENCY", "fieldType": "INPUTOUTPUT" }
  ],
  "_note": "AccountName and SalesRep require relationship traversal (Account.Name, Owner.Name) which the Context Service API does not support in sObjectField. Map those attributes manually in Setup UI after deployment.",
  "mappingRules": [
    { "mappingName": "QuoteDocGenMapping", "contextNode": "Quote", "contextAttribute": "BillingStreet",    "mappingType": "SOBJECT", "sObject": "Quote",         "sObjectField": "BillingStreet" },
    { "mappingName": "QuoteDocGenMapping", "contextNode": "Quote", "contextAttribute": "BillingCity",      "mappingType": "SOBJECT", "sObject": "Quote",         "sObjectField": "BillingCity" },
    { "mappingName": "QuoteDocGenMapping", "contextNode": "Quote", "contextAttribute": "BillingState",     "mappingType": "SOBJECT", "sObject": "Quote",         "sObjectField": "BillingState" },
    { "mappingName": "QuoteDocGenMapping", "contextNode": "Quote", "contextAttribute": "BillingPostalCode","mappingType": "SOBJECT", "sObject": "Quote",         "sObjectField": "BillingPostalCode" },
    { "mappingName": "QuoteDocGenMapping", "contextNode": "Quote", "contextAttribute": "QuoteNumber",      "mappingType": "SOBJECT", "sObject": "Quote",         "sObjectField": "QuoteNumber" },
    { "mappingName": "QuoteDocGenMapping", "contextNode": "Quote", "contextAttribute": "CreatedDate",      "mappingType": "SOBJECT", "sObject": "Quote",         "sObjectField": "CreatedDate" },
    { "mappingName": "QuoteDocGenMapping", "contextNode": "Quote", "contextAttribute": "ExpirationDate",   "mappingType": "SOBJECT", "sObject": "Quote",         "sObjectField": "ExpirationDate" },
    { "mappingName": "QuoteDocGenMapping", "contextNode": "Quote", "contextAttribute": "GrandTotal",       "mappingType": "SOBJECT", "sObject": "Quote",         "sObjectField": "GrandTotal" },
    { "mappingName": "QuoteDocGenMapping", "contextNode": "Line",  "contextAttribute": "ProductName",      "mappingType": "SOBJECT", "sObject": "QuoteLineItem", "sObjectField": "RLM_ProductName__c" },
    { "mappingName": "QuoteDocGenMapping", "contextNode": "Line",  "contextAttribute": "Quantity",         "mappingType": "SOBJECT", "sObject": "QuoteLineItem", "sObjectField": "Quantity" },
    { "mappingName": "QuoteDocGenMapping", "contextNode": "Line",  "contextAttribute": "ListPrice",        "mappingType": "SOBJECT", "sObject": "QuoteLineItem", "sObjectField": "ListPrice" },
    { "mappingName": "QuoteDocGenMapping", "contextNode": "Line",  "contextAttribute": "Discount",         "mappingType": "SOBJECT", "sObject": "QuoteLineItem", "sObjectField": "Discount" },
    { "mappingName": "QuoteDocGenMapping", "contextNode": "Line",  "contextAttribute": "NetUnitPrice",     "mappingType": "SOBJECT", "sObject": "QuoteLineItem", "sObjectField": "UnitPrice" },
    { "mappingName": "QuoteDocGenMapping", "contextNode": "Line",  "contextAttribute": "NetTotalPrice",    "mappingType": "SOBJECT", "sObject": "QuoteLineItem", "sObjectField": "TotalPrice" }
  ],
  "contextTagsByName": [
