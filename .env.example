# CumulusCI Docker Environment Variables
#
# Copy this file to .env and fill in your values
# The .env file is gitignored to protect sensitive data

# CumulusCI Encryption Key (REQUIRED for org sharing)
# Extract your key with: ./docker/get-cci-key.sh
# This key is used to encrypt/decrypt org credential files
# Without this, orgs created in Docker won't be readable on host and vice versa
CUMULUSCI_KEY=

# For CI/CD: DevHub SFDX Auth URL (when using docker-compose.ci.yml)
# Generate with: sf org display --verbose -o YourDevHub | grep "Sfdx Auth Url"
# SFDX_AUTH_URL=
