# CumulusCI Docker Environment Variables
#
# Copy this file to .env and fill in your values
# The .env file is gitignored to protect sensitive data

# Required: Dev Hub SFDX Auth URL
# Generate with: sf org display --verbose -o YourDevHub | grep "Sfdx Auth Url"
SFDX_AUTH_URL=

# Optional override for the container Dev Hub alias.
# You normally do NOT need to set this. Default auto alias is: dockerDevHub
# DOCKER_DEVHUB_ALIAS=dockerDevHub

# Container networking mode
# - bridge (default, most portable)
# - host (useful for localhost OAuth callback behavior)
DOCKER_NETWORK_MODE=bridge

# Optional break-glass compatibility override for container-only troubleshooting.
# Keep this unset (or false) in normal use so SF CLI encryption stays enabled in Docker.
# Never set this globally in your host shell profile.
# SF_DISABLE_ENCRYPTION=false

# Optional per-org auth URLs for EnvironmentProjectKeychain:
# CUMULUSCI_ORG_<orgname>=force://PlatformCLI::...
