# Build-context excludes for the Docker image (docker/Dockerfile).
# Goal: bake a lean, reproducible snapshot of the repo source while leaving out
# local state, caches, secrets, and large runtime-only output dirs.
#
# NOTE: this file governs every `docker build` whose context is the repo root.
# Keep it to *exclusions only* — anything not listed here is copied into the
# image at `COPY . /opt/rlm-base-dev`.

# Version control + CI noise
.git
.gitattributes
.github

# Local Python / Node toolchains (reinstalled inside the image)
.venv
venv
node_modules
**/__pycache__
**/*.pyc
**/*.pyo
.pytest_cache
.ruff_cache
.mypy_cache

# Local environment / secret files (mirror .gitignore — NEVER bake into layers)
.env
.env.*
*.key
*.pem

# Salesforce / CumulusCI local auth + keychain + caches (NEVER bake secrets)
.sf
.sfdx
.cci
.cumulusci

# Build-harness run artifacts + scenario workspaces
.harness

# Runtime-only extract outputs (regenerated by extract_* tasks)
datasets/bre
datasets/dx

# Editor / OS cruft
.DS_Store
**/.DS_Store
.vscode
.idea
*.swp

# Logs and scratch
*.log
tmp
scratch
